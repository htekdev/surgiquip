# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare file types
*.md    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.astro text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.svg   text eol=lf
