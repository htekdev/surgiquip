# Google Analytics 4 Measurement ID
# Set this in Vercel environment variables before launch (e.g. G-XXXXXXXXXX)
# Leave blank during development — GA4 script will not load unless this is set.
PUBLIC_GA4_ID=

# Formspree CLI deploy key — get from Formspree Dashboard → Settings → API Keys
# Used only for `npx @formspree/cli deploy` (not needed at runtime)
# Also stored as GitHub secret FORMSPREE_DEPLOY_KEY for CI/CD
FORMSPREE_DEPLOY_KEY=
