---
import { site } from '~/data/site';
// Inter — used for both headlines and body. Headlines use 700/800 weights.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
// K2: Critical font preload — Vite ?url resolves to content-hashed build path.
// Preloading the two most-rendered weights (Inter 700 for h1/h2, Inter 400 for body)
// eliminates FOIT on headline and body text — reduces CLS and improves FCP/LCP.
import interLatin700Url from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';
import interLatin400Url from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import StickyMobileCTA from '~/components/StickyMobileCTA.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  schema?: object | object[];
  noindex?: boolean;
  /** Absolute path to preload as LCP image hint (e.g. "/images/hero/hero-or-suite.webp") */
  preloadImage?: string;
  /**
   * Open Graph type — defaults to "website".
   * Pass "article" for blog posts so social platforms display article metadata
   * (publish date, author) instead of generic website cards.
   */
  ogType?: 'website' | 'article';
}

const { title, description, canonical, image = '/og-default.png', schema, noindex = false, preloadImage, ogType = 'website' } = Astro.props;

const fullTitle = title.includes(site.short) ? title : `${title} | ${site.brand}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const schemaArray = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* K2: Font preload — critical path fonts for FCP/CLS improvement.
        crossorigin is required for same-origin font preloads (spec requirement).
        Preloading latin subset only — covers all US English content on this site. */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin700Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin400Url} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Favicon package */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a2c5e" />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content={site.brand} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <meta name="generator" content={Astro.generator} />

    {/* Resource hints — reduce connection latency for 3rd-party origins */}
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    <link rel="dns-prefetch" href="//www.google-analytics.com" />
    {import.meta.env.PUBLIC_GA4_ID && (
      <link rel="preconnect" href="https://www.googletagmanager.com" />
    )}

    {/* RSS feed autodiscovery — search engines and feed readers pick this up automatically */}
    <link rel="alternate" type="application/rss+xml" title={`${site.brand} — Surgical Equipment Insights`} href="/rss.xml" />

    {/* Preload LCP hero image when provided — improves Largest Contentful Paint */}
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    {schemaArray.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    {/* GA4 — activated by PUBLIC_GA4_ID env var (set in Vercel before launch) */}
    {import.meta.env.PUBLIC_GA4_ID && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`} />
        <script define:vars={{ _gaId: import.meta.env.PUBLIC_GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', _gaId);
        </script>
      </Fragment>
    )}
  </head>
  <body class="min-h-screen flex flex-col pb-14 lg:pb-0">
    {/* Skip-to-content: critical for keyboard navigation and Lighthouse a11y */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:rounded focus:bg-[var(--color-navy)] focus:text-white focus:font-semibold focus:shadow-lg"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <StickyMobileCTA />
  </body>
</html>
