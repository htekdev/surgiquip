---
import { partners } from '~/data/site';
---
<section class="bg-white border-t border-[var(--color-border)]">
  <div class="container-x py-14">
    <div class="text-center text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-8">Our Partners</div>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      {partners.map((p) => (
        <div class="flex items-center justify-center h-12 md:h-14 w-32 md:w-40">
          {p.logo ? (
            <img
              src={p.logo}
              alt={`${p.label} logo`}
              class="max-h-full max-w-full object-contain"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="font-display font-bold text-sm text-[var(--color-navy)]">
              {p.label}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
