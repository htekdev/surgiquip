---
import { partners } from '~/data/site';
---
<section class="bg-white border-t border-[var(--color-border)]">
  <div class="container-x py-14">
    <div class="text-center text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-8">Our Partners</div>
    <div class="flex flex-wrap justify-center items-center gap-10 md:gap-14">
      {partners.map((p) => (
        <div class="flex items-center justify-center">
          {p.logo ? (
            <img
              src={p.logo}
              alt={`${p.label} logo`}
              class:list={['h-10 md:h-12 w-auto object-contain', { 'dark:invert': p.invertOnLight, 'bg-[var(--color-navy)] rounded px-3 py-2': p.invertOnLight }]}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="inline-block px-6 py-4 border border-[var(--color-border)] rounded font-display font-bold text-lg text-[var(--color-navy)]">
              {p.label}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
