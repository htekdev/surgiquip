---
export interface Props {
  class?: string;
  variant?: 'navy' | 'white';
}
const { class: className = '', variant = 'navy' } = Astro.props;
---
<img
  src="/images/surgiquip-logo-header.webp"
  alt="Surgiquip Solutions logo"
  class:list={[className, { 'brightness-0 invert': variant === 'white' }]}
  width="334"
  height="96"
  loading="eager"
  decoding="async"
/>
