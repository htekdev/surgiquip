---
export interface Props {
  class?: string;
  variant?: 'navy' | 'white';
}
const { class: className = '', variant = 'navy' } = Astro.props;
const src = variant === 'white'
  ? '/images/surgiquip-logo-header-white.webp'
  : '/images/surgiquip-logo-header.webp';
---
<img
  src={src}
  alt="Surgiquip Solutions logo"
  class={className}
  width="334"
  height="96"
  loading="eager"
  decoding="async"
/>
