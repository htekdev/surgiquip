---
/**
 * ProductCatalog.astro — Clean visual category tiles
 *
 * Level 1 of the 2-level product hierarchy.
 * Shows ONE image per product category — click to drill down.
 * No filters, no dropdowns — just clean visual tiles.
 */
import type { Category } from '~/data/products';

interface Props {
  categories: (Category & { count: number })[];
}

const { categories } = Astro.props;
---

<section id="catalog" class="container-x py-16">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {categories.map((cat) => (
      <a
        href={`/products/${cat.slug}`}
        class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-blue)]/40"
      >
        {/* Category image — dominant visual */}
        <div class="relative aspect-[4/3] overflow-hidden bg-[var(--color-surface-alt)]">
          <img
            src={cat.image}
            alt={cat.alt}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          {/* Product count badge */}
          <div class="absolute top-3 right-3">
            <span class="rounded-full bg-white/90 px-2.5 py-0.5 text-xs font-semibold text-[var(--color-navy)] backdrop-blur-sm">
              {cat.count} {cat.count === 1 ? 'product' : 'products'}
            </span>
          </div>
        </div>

        {/* Label */}
        <div class="flex flex-1 flex-col p-6">
          <h2 class="text-xl font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition-colors">
            {cat.name}
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)] flex-1">
            {cat.description}
          </p>
          <div class="mt-4 flex items-center gap-1.5 text-sm font-semibold text-[var(--color-blue)]">
            Browse {cat.name.toLowerCase()}
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

