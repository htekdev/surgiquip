---
/**
 * ProductCatalog.astro — Full-page filterable product grid
 *
 * Store-like visual catalog showing ALL products in a flat, filterable grid.
 * Inspired by Innovative Medical USA's visual-first product layout.
 *
 * Filters are client-side (vanilla JS) for instant interaction.
 */
import type { Product, ProductCategory } from '~/data/products';

interface Props {
  products: Product[];
  categories: ProductCategory[];
  brands: readonly string[];
}

const { products, categories, brands } = Astro.props;
---

<section id="catalog" class="container-x py-16">
  <!-- ── Filter Bar ── -->
  <div class="mb-10">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">
          Equipment Catalog
        </div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] md:text-4xl">
          All Products
        </h2>
        <p class="mt-2 text-[var(--color-text-muted)]">
          <span id="product-count">{products.length}</span> products available
        </p>
      </div>

      <!-- Filter controls -->
      <div class="flex flex-wrap gap-3" id="filter-controls">
        <!-- Category filter -->
        <div class="relative">
          <select
            id="filter-category"
            class="appearance-none rounded-lg border border-[var(--color-border)] bg-white px-4 py-2.5 pr-9 text-sm font-medium text-[var(--color-navy)] transition hover:border-[var(--color-blue)] focus:border-[var(--color-blue)] focus:ring-2 focus:ring-[var(--color-blue)]/20 focus:outline-none cursor-pointer"
            aria-label="Filter by product category"
          >
            <option value="all">All Categories</option>
            {categories.map((cat) => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--color-text-muted)]" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" />
          </svg>
        </div>

        <!-- Brand filter -->
        <div class="relative">
          <select
            id="filter-brand"
            class="appearance-none rounded-lg border border-[var(--color-border)] bg-white px-4 py-2.5 pr-9 text-sm font-medium text-[var(--color-navy)] transition hover:border-[var(--color-blue)] focus:border-[var(--color-blue)] focus:ring-2 focus:ring-[var(--color-blue)]/20 focus:outline-none cursor-pointer"
            aria-label="Filter by brand"
          >
            <option value="all">All Brands</option>
            {brands.map((brand) => (
              <option value={brand}>{brand}</option>
            ))}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--color-text-muted)]" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" />
          </svg>
        </div>

        <!-- Reset button (hidden by default) -->
        <button
          id="filter-reset"
          class="hidden items-center gap-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] px-4 py-2.5 text-sm font-medium text-[var(--color-text-muted)] transition hover:text-[var(--color-navy)] hover:border-[var(--color-navy)]"
          aria-label="Clear all filters"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          Clear
        </button>
      </div>
    </div>

    <!-- Quick category pills (mobile-friendly) -->
    <div class="mt-5 flex flex-wrap gap-2" id="category-pills">
      <button
        data-pill="all"
        class="rounded-full px-4 py-1.5 text-sm font-semibold transition border border-[var(--color-blue)] bg-[var(--color-blue)] text-white"
        aria-pressed="true"
      >
        All
      </button>
      {categories.map((cat) => (
        <button
          data-pill={cat}
          class="rounded-full px-4 py-1.5 text-sm font-semibold transition border border-[var(--color-border)] bg-white text-[var(--color-navy)] hover:border-[var(--color-blue)] hover:text-[var(--color-blue)]"
          aria-pressed="false"
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- ── Product Grid ── -->
  <div
    id="product-grid"
    class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    role="list"
    aria-label="Product catalog"
  >
    {products.map((product) => (
      <a
        href={product.href}
        class="product-card group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-blue)]/40"
        data-category={product.category}
        data-brand={product.brand}
        role="listitem"
      >
        {/* Image */}
        <div class="relative aspect-[4/3] overflow-hidden bg-[var(--color-surface-alt)]">
          <img
            src={product.image}
            alt={product.alt}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          {/* Brand badge */}
          <div class="absolute top-3 left-3 flex items-center gap-2">
            <span class="rounded-full bg-[var(--color-navy)]/90 px-2.5 py-0.5 text-[10px] font-bold tracking-widest uppercase text-white backdrop-blur-sm">
              {product.brand}
            </span>
            {product.badge && (
              <span class="rounded-full bg-[var(--color-blue)] px-2.5 py-0.5 text-[10px] font-bold tracking-widest uppercase text-white">
                {product.badge}
              </span>
            )}
          </div>
          {/* Category tag */}
          <div class="absolute bottom-3 left-3">
            <span class="rounded-md bg-white/90 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-text-muted)] backdrop-blur-sm">
              {product.category}
            </span>
          </div>
        </div>

        {/* Content */}
        <div class="flex flex-1 flex-col p-5">
          <h3 class="text-base font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition-colors leading-snug">
            {product.name}
          </h3>
          <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2">
            {product.tagline}
          </p>

          {/* Spec highlights */}
          {product.specs && product.specs.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {product.specs.map((spec) => (
                <span class="rounded-md bg-[var(--color-surface-alt)] px-2 py-0.5 text-[11px] font-medium text-[var(--color-navy)]">
                  {spec}
                </span>
              ))}
            </div>
          )}

          {/* CTA */}
          <div class="mt-auto pt-4 flex items-center gap-1.5 text-sm font-semibold text-[var(--color-blue)]">
            View details
            <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- ── Empty state ── -->
  <div id="empty-state" class="hidden py-16 text-center">
    <div class="mx-auto max-w-md">
      <svg class="mx-auto h-12 w-12 text-[var(--color-text-muted)]/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" />
      </svg>
      <p class="mt-4 text-lg font-semibold text-[var(--color-navy)]">No products match your filters</p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">Try adjusting your category or brand selection.</p>
      <button
        id="empty-reset"
        class="mt-4 inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-4 py-2 text-sm font-semibold text-[var(--color-navy)] hover:border-[var(--color-navy)] transition"
      >
        Clear all filters
      </button>
    </div>
  </div>
</section>

<script>
  // ── Client-side product filtering ──────────────────────────────────────
  const grid = document.getElementById('product-grid')!;
  const cards = grid.querySelectorAll<HTMLElement>('.product-card');
  const countEl = document.getElementById('product-count')!;
  const emptyState = document.getElementById('empty-state')!;
  const categorySelect = document.getElementById('filter-category') as HTMLSelectElement;
  const brandSelect = document.getElementById('filter-brand') as HTMLSelectElement;
  const resetBtn = document.getElementById('filter-reset')!;
  const emptyResetBtn = document.getElementById('empty-reset')!;
  const pills = document.querySelectorAll<HTMLButtonElement>('#category-pills button');

  function applyFilters() {
    const cat = categorySelect.value;
    const brand = brandSelect.value;
    let visible = 0;

    cards.forEach((card) => {
      const cardCat = card.dataset.category;
      const cardBrand = card.dataset.brand;
      const matchCat = cat === 'all' || cardCat === cat;
      const matchBrand = brand === 'all' || cardBrand === brand;
      const show = matchCat && matchBrand;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    countEl.textContent = String(visible);
    emptyState.classList.toggle('hidden', visible > 0);
    grid.classList.toggle('hidden', visible === 0);

    // Show/hide reset button
    const hasFilter = cat !== 'all' || brand !== 'all';
    resetBtn.classList.toggle('hidden', !hasFilter);
    resetBtn.classList.toggle('inline-flex', hasFilter);

    // Sync pills with category select
    pills.forEach((pill) => {
      const val = pill.dataset.pill!;
      const isActive = val === cat || (val === 'all' && cat === 'all');
      pill.setAttribute('aria-pressed', String(isActive));
      if (isActive) {
        pill.className = 'rounded-full px-4 py-1.5 text-sm font-semibold transition border border-[var(--color-blue)] bg-[var(--color-blue)] text-white';
      } else {
        pill.className = 'rounded-full px-4 py-1.5 text-sm font-semibold transition border border-[var(--color-border)] bg-white text-[var(--color-navy)] hover:border-[var(--color-blue)] hover:text-[var(--color-blue)]';
      }
    });
  }

  function resetFilters() {
    categorySelect.value = 'all';
    brandSelect.value = 'all';
    applyFilters();
  }

  categorySelect.addEventListener('change', applyFilters);
  brandSelect.addEventListener('change', applyFilters);
  resetBtn.addEventListener('click', resetFilters);
  emptyResetBtn.addEventListener('click', resetFilters);

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      categorySelect.value = pill.dataset.pill === 'all' ? 'all' : pill.dataset.pill!;
      applyFilters();
    });
  });
</script>

