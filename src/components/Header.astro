---
import { nav, site } from '~/data/site';
import Logo from './Logo.astro';
---
<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-[var(--color-border)]">
  <div class="container-x flex items-center justify-between gap-6 h-20">
    <a href="/" aria-label="Surgiquip Solutions — home" class="flex items-center gap-3 shrink-0">
      <Logo class="h-12 w-auto" />
      <div class="hidden sm:block leading-tight">
        <div class="font-display text-xl font-extrabold tracking-tight text-[var(--color-navy)]">Surgiquip</div>
        <div class="text-xs text-[var(--color-text-muted)]">Solutions, Inc.</div>
        <div class="text-[10px] italic text-[var(--color-text-muted)]">"{site.tagline}"</div>
      </div>
    </a>

    <nav aria-label="Primary navigation" class="hidden lg:flex items-center gap-7 text-sm font-medium text-[var(--color-text)]">
      {nav.map((item) => (
        <div class="relative group" data-nav-item>
          <a
            href={item.href}
            aria-haspopup={item.children ? "true" : undefined}
            aria-expanded={item.children ? "false" : undefined}
            class="hover:text-[var(--color-blue)] transition flex items-center gap-1"
          >
            {item.label}
            {item.children && (
              <svg class="w-3 h-3" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" />
              </svg>
            )}
          </a>
          {item.children && (
            <ul
              role="list"
              class="absolute top-full left-0 mt-2 min-w-[220px] bg-white border border-[var(--color-border)] rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition py-1"
            >
              {item.children.map((child) => (
                <li>
                  <a href={child.href} class="block px-4 py-2.5 text-sm hover:bg-[var(--color-surface-alt)] hover:text-[var(--color-blue)]">
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a href="/quote" class="btn-primary text-sm hidden md:inline-flex">Request Quote</a>
      <a href={`tel:${site.phoneE164}`} class="hidden md:flex items-center gap-2 text-sm font-semibold text-[var(--color-navy)] hover:text-[var(--color-blue)]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/>
        </svg>
        {site.phone}
      </a>
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6 text-[var(--color-navy)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-white">
    <nav aria-label="Mobile navigation" class="container-x py-4 flex flex-col gap-1">
      {nav.map((item) => (
        <div>
          <a href={item.href} class="block py-2.5 px-3 rounded font-medium hover:bg-[var(--color-surface-alt)]">{item.label}</a>
          {item.children && (
            <div class="pl-4 flex flex-col gap-0.5 mt-0.5 mb-1">
              {item.children.map((child) => (
                <a href={child.href} class="block py-2 px-3 rounded text-sm text-[var(--color-text-muted)] hover:bg-[var(--color-surface-alt)] hover:text-[var(--color-blue)]">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <a href="/quote" class="btn-primary mt-3 justify-center">Request Quote</a>
      <a href={`tel:${site.phoneE164}`} class="text-center py-3 font-semibold text-[var(--color-navy)]">📞 {site.phone}</a>
    </nav>
  </div>
</header>

<script>
  // ── Mobile menu toggle ────────────────────────────────────────────────────
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open navigation menu');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    isOpen ? closeMenu() : openMenu();
  });

  // ── Desktop nav dropdown: aria-expanded + Escape key support ─────────────
  // Each [data-nav-item] with a child <ul> tracks expanded state via
  // focus-within CSS and aria-expanded on the parent <a> for screen readers.
  const navItems = document.querySelectorAll<HTMLElement>('[data-nav-item]');

  navItems.forEach((item) => {
    const trigger = item.querySelector<HTMLAnchorElement>('a[aria-haspopup]');
    const dropdown = item.querySelector<HTMLUListElement>('ul[role="list"]');
    if (!trigger || !dropdown) return;

    // Update aria-expanded whenever focus enters/leaves the group
    item.addEventListener('focusin', () => {
      trigger.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('focusout', (e) => {
      // Only collapse when focus leaves the entire nav item
      if (!item.contains((e as FocusEvent).relatedTarget as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // ── Escape key: close both mobile menu and desktop dropdowns ─────────────
  // WCAG 2.1 SC 2.1.2 — keyboard trap prevention
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;

    // Close mobile menu if open
    if (menu && !menu.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
      return;
    }

    // Collapse any open desktop dropdown (return focus to its trigger)
    const focused = document.activeElement as HTMLElement | null;
    const activeItem = focused?.closest<HTMLElement>('[data-nav-item]');
    if (activeItem) {
      const trigger = activeItem.querySelector<HTMLAnchorElement>('a[aria-haspopup]');
      if (trigger) {
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    }
  });
</script>
