---
import { stats } from '~/data/site';
const iconPaths: string[] = [
  '<rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" fill="none"/>',
  '<rect x="4" y="3" width="16" height="18" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 8h2M14 8h2M8 12h2M14 12h2M8 16h2M14 16h2" stroke="currentColor" stroke-width="1.5"/>',
  '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
];
---
<section class="bg-white border-b border-[var(--color-border)]">
  <div class="container-x py-12 grid grid-cols-2 lg:grid-cols-4 gap-8">
    {stats.map((stat, i) => (
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-12 h-12 rounded-full bg-[var(--color-surface-alt)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-navy)]">
          <svg class="w-6 h-6" viewBox="0 0 24 24" set:html={iconPaths[i]} />
        </div>
        <div>
          <div class="font-display text-xl font-bold text-[var(--color-navy)] leading-tight">{stat.value}</div>
          <div class="text-sm text-[var(--color-text-muted)] leading-tight mt-1">{stat.label}<br/>{stat.sub}</div>
        </div>
      </div>
    ))}
  </div>
</section>
