---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const canonicalUrl = `${site.url}/blog`;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Surgical Equipment Resources & Insights | Surgiquip Solutions',
  description:
    'Expert insights on surgical equipment, OR installation planning, and healthcare facility management from Surgiquip Solutions — Houston\'s authorized Skytron dealer.',
  url: canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: site.brand,
    url: site.url,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: canonicalUrl },
  ],
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Surgical Equipment Resources & Insights | Surgiquip Solutions"
  description="Expert insights on surgical equipment, OR installation planning, and healthcare facility management from Surgiquip Solutions — Houston's authorized Skytron dealer since 1983."
  canonical={canonicalUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  {/* Page hero */}
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li class="text-white/90" aria-current="page">Blog</li>
        </ol>
      </nav>

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-xs font-semibold text-white/80 tracking-widest uppercase mb-6">
        Resources & Insights
      </div>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment Expertise for Texas Healthcare
      </h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl leading-relaxed">
        Planning an OR installation, evaluating equipment suppliers, or optimizing your facility's surgical suite? Our team shares practical insights from 43 years of field experience.
      </p>
    </div>
  </section>

  {/* Posts grid */}
  <section class="container-x py-16">
    {posts.length === 0 ? (
      <p class="text-[var(--color-text-muted)] text-center py-16">No posts yet — check back soon.</p>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-white hover:border-[var(--color-blue)] hover:shadow-md transition overflow-hidden">
            <div class="p-6 flex flex-col flex-1">
              {/* Tags */}
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full bg-[var(--color-surface-alt)] text-[var(--color-blue)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <h2 class="font-display text-lg font-bold text-[var(--color-navy)] leading-snug mb-3 group-hover:text-[var(--color-blue)] transition">
                <a href={`/blog/${post.id}`} class="stretched-link">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
                {post.data.description}
              </p>
              <div class="mt-5 pt-4 border-t border-[var(--color-border)] flex items-center justify-between text-xs text-[var(--color-text-muted)]">
                <time datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
                <span class="text-[var(--color-blue)] font-semibold group-hover:underline">Read →</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <CTASection
    heading="43 Years of Surgical Equipment Expertise"
    subhead="From OR installations to preventive maintenance programs, Surgiquip Solutions serves hospitals and surgical centers across Southeast Texas."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Call (713) 681-6362"
    secondaryHref="tel:+17136816362"
  />
</BaseLayout>
