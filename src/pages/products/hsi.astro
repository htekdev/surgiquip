---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const products = [
  {
    name: 'Surgical Boom Systems',
    description: 'HSI ceiling-mounted equipment management arms with integrated power, gas, and data. Engineered for surgical suite efficiency — keep floor space clear and workflows moving.',
  },
  {
    name: 'Operating Room Furniture',
    description: 'Durable, hospital-grade OR cabinetry, storage, and furniture systems designed for clinical environments. Easy to clean, built to last, and customizable to your layout.',
  },
  {
    name: 'Patient Care Equipment',
    description: 'Stretchers, transfer systems, and patient positioning products from HSI — designed for safety, workflow efficiency, and caregiver ergonomics.',
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'HSI Hospital Systems Products — Surgiquip Solutions Houston TX',
  description: 'HSI Hospital Systems, Inc. surgical and patient care equipment. Sales and service in Southeast Texas by Surgiquip Solutions.',
  url: `${site.url}/products/hsi`,
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${site.url}#organization`,
    name: site.brand,
    areaServed: 'South Texas',
  },
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      description: p.description,
      brand: { '@type': 'Brand', name: 'HSI Hospital Systems, Inc.' },
      offers: {
        '@type': 'Offer',
        seller: { '@id': `${site.url}#organization` },
        areaServed: 'South Texas',
        availability: 'https://schema.org/InStock',
        priceSpecification: { '@type': 'PriceSpecification', priceCurrency: 'USD' },
      },
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${site.url}/products` },
    { '@type': 'ListItem', position: 3, name: 'HSI Hospital Systems', item: `${site.url}/products/hsi` },
  ],
};
---
<BaseLayout
  title="HSI Hospital Systems | Surgiquip Solutions"
  description="HSI Hospital Systems boom systems, OR furniture, and patient care equipment. Authorized dealer in South Texas. Contact Surgiquip Solutions today."
  schema={[productSchema, breadcrumbSchema]}
  preloadImage="/images/products/hsi-hero.webp"
>
  <section class="bg-[var(--color-navy)] text-white overflow-hidden">
    <div class="container-x py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
            <a href="/" class="hover:text-white/90">Home</a>
            <span class="mx-2">/</span>
            <a href="/products" class="hover:text-white/90">Products</a>
            <span class="mx-2">/</span>
            <span class="text-white/90">HSI</span>
          </nav>
          <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-xs font-bold tracking-widest uppercase text-white/80 mb-4">
            Authorized Dealer
          </div>
          <h1 class="font-display text-4xl md:text-5xl font-bold mt-2 text-white leading-tight">
            HSI Hospital Systems, Inc.
          </h1>
          <p class="mt-5 text-lg text-white/85 max-w-xl leading-relaxed">
            Surgiquip Solutions is an authorized dealer for HSI Hospital Systems products in Southeast Texas — ceiling-mounted boom systems, OR furniture, and patient care equipment built for the modern surgical environment.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Request a Quote</a>
            <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-white/30 text-white font-semibold hover:bg-white/10 transition text-sm">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
              {site.phone}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/products/hsi-hero.webp"
            alt="HSI Hospital Systems ceiling-mounted OR boom arms and surgical suite equipment — Surgiquip Solutions Houston TX"
            class="rounded-2xl shadow-2xl object-cover w-full aspect-[4/3]"
            loading="eager"
            decoding="async"
            width="768"
            height="576"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-2xl mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Product Line</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">HSI Products We Supply</h2>
      <p class="mt-3 text-[var(--color-text-muted)] leading-relaxed">
        HSI Hospital Systems, Inc. manufactures high-quality surgical environment and patient care equipment. As an authorized dealer, Surgiquip provides these products with full service and installation support.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {products.map((product) => (
        <div class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition flex flex-col">
          <div class="w-10 h-10 rounded-lg bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="font-bold text-[var(--color-navy)] mb-2">{product.name}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{product.description}</p>
          <a href="/quote" class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)] hover:underline">
            Request Quote
            <svg class="w-3.5 h-3.5" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] max-w-2xl">
      <div class="font-bold text-[var(--color-navy)] mb-2">Full Product Catalog Available on Request</div>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
        HSI offers an extensive product catalog beyond the highlights above. Contact our team with your specific facility needs and we'll identify the right HSI solutions for your project.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary text-sm">Contact Our Team</a>
        <a href="/products" class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border)] text-sm font-semibold text-[var(--color-navy)] hover:border-[var(--color-navy)] transition">
          All Products
        </a>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Specify HSI Equipment for Your Project?"
    subhead="Our team will work with you to select the right products, prepare specs, and manage installation. Tell us about your facility."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel={`Call ${site.phone}`}
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>

