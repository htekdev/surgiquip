---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const products = [
  {
    name: 'Surgical Tables',
    description: 'Precision-engineered operating tables with multi-articulation, memory positioning, and radiolucent tabletops. Built to support complex surgical procedures for 20+ years.',
    image: '/images/products/surgical-table.png',
    keywords: 'Skytron surgical table, OR table, operating table Houston',
  },
  {
    name: 'Surgical Lights',
    description: 'Advanced LED overhead lighting systems with adjustable color temperature, shadow management, and integrated camera systems for the modern OR.',
    image: '/images/products/surgical-light.png',
    keywords: 'Skytron surgical light, OR light, LED surgical light Houston',
  },
  {
    name: 'Equipment Booms',
    description: 'Ceiling-mounted equipment management arms with integrated gas, electrical, and data connections. Keep your OR floor clear and workflow efficient.',
    image: '/images/products/equipment-boom.png',
    keywords: 'Skytron equipment boom, OR boom, ceiling boom Houston',
  },
  {
    name: 'OR Integration',
    description: 'Complete hybrid operating room solutions combining tables, lights, booms, and AV integration into one seamless surgical environment.',
    image: '/images/products/or-integration.png',
    keywords: 'hybrid OR integration, OR AV system, operating room integration Houston',
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Skytron Surgical Equipment — Authorized Dealer Southeast Texas',
  description: 'Full line of Skytron surgical tables, lights, booms, and OR integration systems. Sales, installation, and service in Southeast Texas.',
  url: `${site.url}/products/skytron`,
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${site.url}#organization`,
    name: site.brand,
    areaServed: 'Southeast Texas',
  },
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `Skytron ${p.name}`,
      description: p.description,
      image: `${site.url}${p.image}`,
      brand: { '@type': 'Brand', name: 'Skytron' },
      offers: {
        '@type': 'Offer',
        seller: { '@id': `${site.url}#organization` },
        areaServed: 'Southeast Texas',
        availability: 'https://schema.org/InStock',
        priceSpecification: { '@type': 'PriceSpecification', priceCurrency: 'USD' },
      },
    },
  })),
};
---
<BaseLayout
  title="Skytron Surgical Equipment | Authorized Dealer Houston TX | Surgiquip"
  description="Authorized Skytron dealer for Southeast Texas. Surgical tables, lights, booms, and complete OR integration solutions. Sales, installation, and service."
  schema={productSchema}
>
  <section class="bg-[var(--color-navy)] text-white overflow-hidden">
    <div class="container-x py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
            <a href="/" class="hover:text-white/90">Home</a>
            <span class="mx-2">/</span>
            <a href="/products" class="hover:text-white/90">Products</a>
            <span class="mx-2">/</span>
            <span class="text-white/90">Skytron</span>
          </nav>
          <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-3 py-1 text-xs font-bold tracking-widest uppercase text-white/80 mb-4">
            Authorized Dealer
          </div>
          <h1 class="font-display text-4xl md:text-5xl font-bold mt-2 text-white leading-tight">
            Skytron® Surgical Equipment for Southeast Texas
          </h1>
          <p class="mt-5 text-lg text-white/85 max-w-xl leading-relaxed">
            As Skytron's exclusive authorized dealer for Southeast Texas, we provide the full product line — sales, installation, training, and ongoing service support backed by 43 years of expertise.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Request a Quote</a>
            <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-white/30 text-white font-semibold hover:bg-white/10 transition text-sm">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
              {site.phone}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/products/skytron-hero.png"
            alt="Premium Skytron surgical suite — OR lights, equipment booms, and surgical table setup"
            class="rounded-2xl shadow-2xl object-cover w-full aspect-[4/3]"
            loading="eager"
            decoding="async"
            width="768"
            height="576"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Skytron Banner -->
  <section class="bg-[var(--color-surface-alt)] border-b border-[var(--color-border)]">
    <div class="container-x py-6">
      <div class="flex flex-wrap items-center gap-6 text-sm text-[var(--color-text-muted)]">
        <div class="flex items-center gap-2 font-semibold text-[var(--color-navy)]">
          <svg class="w-5 h-5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke-linecap="round"/></svg>
          Factory Authorized
        </div>
        <div class="w-px h-4 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
        <span>Exclusive Southeast Texas dealer</span>
        <div class="w-px h-4 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
        <span>Full product line: tables, lights, booms, OR integration</span>
        <div class="w-px h-4 bg-[var(--color-border)] hidden sm:block" aria-hidden="true"></div>
        <span>Factory-certified installation &amp; service</span>
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="container-x py-16">
    <div class="max-w-2xl mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Product Line</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">The Complete Skytron Catalog</h2>
      <p class="mt-3 text-[var(--color-text-muted)]">
        Every product we sell is backed by factory-authorized installation, training, and ongoing service. No gray-market equipment. No unauthorized dealers.
      </p>
    </div>

    <div class="grid gap-12 md:gap-16">
      {products.map((product, i) => (
        <div class={`flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-8 md:gap-12`}>
          <div class="w-full md:w-1/2">
            <img
              src={product.image}
              alt={`Skytron ${product.name} — Surgiquip Solutions`}
              class="w-full rounded-xl shadow-lg border border-[var(--color-border)]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-navy)]">Skytron {product.name}</h2>
            <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">{product.description}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/quote" class="inline-flex items-center gap-2 btn-primary text-sm">
                Request Quote
                <svg class="w-4 h-4" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
              </a>
              <a href="/services/service-and-repair" class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border)] text-sm font-semibold text-[var(--color-navy)] hover:border-[var(--color-navy)] transition">
                Service &amp; Repair
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Dealer Credentials -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-10">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Buy from Surgiquip</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Authorized Means Protected</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          Purchasing Skytron equipment from an authorized dealer protects your warranty, your Joint Commission status, and your investment.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {[
          {
            title: 'Factory Warranty',
            desc: "All Skytron equipment sold by Surgiquip carries full factory warranty. Unauthorized resellers cannot offer this protection.",
            icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" fill="none"/>',
          },
          {
            title: 'Certified Installation',
            desc: 'Our technicians are factory-trained and certified for every Skytron product we sell. Installation is performed to manufacturer specifications.',
            icon: '<path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
          },
          {
            title: 'Ongoing Service Access',
            desc: 'As the local authorized dealer, we stock Skytron parts and can dispatch factory-trained service technicians faster than any out-of-market provider.',
            icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
          },
        ].map((item) => (
          <div class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Need Help Choosing the Right Skytron Configuration?"
    subhead="Our team can assess your facility's needs and recommend the ideal setup. 43 years of Skytron expertise at your service."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel={`Call ${site.phone}`}
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
