---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';
import { categories, getProductsByCategory, getCategoryBySlug } from '~/data/products';

// ---------------------------------------------------------------------------
// Static paths — generate one page per category
// ---------------------------------------------------------------------------
export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.slug },
  }));
}

const { category: categorySlug } = Astro.params;
const category = getCategoryBySlug(categorySlug!)!;
const categoryProducts = getProductsByCategory(categorySlug!);

// ---------------------------------------------------------------------------
// Schema.org
// ---------------------------------------------------------------------------
const productListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${category.name} — Surgiquip Solutions`,
  description: category.description,
  url: `${site.url}/products/${category.slug}`,
  numberOfItems: categoryProducts.length,
  itemListElement: categoryProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${site.url}/products/${p.category}/${p.slug}`,
    name: p.name,
    item: {
      '@type': 'Product',
      name: p.name,
      description: p.tagline,
      image: `${site.url}${p.image}`,
      brand: { '@type': 'Brand', name: p.brand },
      offers: {
        '@type': 'Offer',
        seller: { '@id': `${site.url}#organization` },
        areaServed: 'South Texas',
        availability: 'https://schema.org/InStock',
      },
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${site.url}/products` },
    { '@type': 'ListItem', position: 3, name: category.name, item: `${site.url}/products/${category.slug}` },
  ],
};
---
<BaseLayout
  title={`${category.name} | Surgiquip Solutions`}
  description={`${category.description} Authorized dealer for South Texas hospitals and surgery centers since 1983.`}
  schema={[productListSchema, breadcrumbSchema]}
>
  <!-- ── Hero ── -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-14 md:py-16">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Surgiquip</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-white/90">Products</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">{category.name}</span>
      </nav>
      <h1 class="max-w-3xl font-display text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        {category.name}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/80">
        {category.description}
      </p>
      <p class="mt-3 text-sm text-white/60">
        {categoryProducts.length} {categoryProducts.length === 1 ? 'product' : 'products'} available
      </p>
    </div>
  </section>

  <!-- ── Product Grid ── -->
  <section class="container-x py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {categoryProducts.map((product) => (
        <a
          href={`/products/${product.category}/${product.slug}`}
          class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-blue)]/40"
        >
          {/* Product image */}
          <div class="relative aspect-[4/3] overflow-hidden bg-[var(--color-surface-alt)]">
            <img
              src={product.image}
              alt={product.alt}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-3 left-3 flex items-center gap-2">
              <span class="rounded-full bg-[var(--color-navy)]/90 px-2.5 py-0.5 text-[10px] font-bold tracking-widest uppercase text-white backdrop-blur-sm">
                {product.brand}
              </span>
              {product.badge && (
                <span class="rounded-full bg-[var(--color-blue)] px-2.5 py-0.5 text-[10px] font-bold tracking-widest uppercase text-white">
                  {product.badge}
                </span>
              )}
            </div>
          </div>

          {/* Content */}
          <div class="flex flex-1 flex-col p-6">
            <h2 class="text-lg font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition-colors">
              {product.name}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
              {product.tagline}
            </p>

            {/* Spec pills */}
            {product.specs && product.specs.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {product.specs.map((spec) => (
                  <span class="rounded-md bg-[var(--color-surface-alt)] px-2.5 py-1 text-[11px] font-medium text-[var(--color-navy)]">
                    {spec}
                  </span>
                ))}
              </div>
            )}

            {/* CTA */}
            <div class="mt-auto pt-5 flex items-center gap-1.5 text-sm font-semibold text-[var(--color-blue)]">
              View details
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* Back to all categories */}
    <div class="mt-12 text-center">
      <a
        href="/products"
        class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-semibold text-[var(--color-navy)] transition hover:border-[var(--color-navy)]"
      >
        <svg class="h-4 w-4" viewBox="0 0 12 12" aria-hidden="true">
          <path d="M10 6H3M6 9L3 6l3-3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
        </svg>
        All Product Categories
      </a>
    </div>
  </section>

  <CTASection
    heading={`Need a Quote for ${category.name}?`}
    subhead="Tell us about your facility requirements and we'll recommend the right configuration for your project."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel={`Call ${site.phone}`}
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
