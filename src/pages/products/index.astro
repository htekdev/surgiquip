---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductCatalog from '~/components/ProductCatalog.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';
import { products, productCategories, brands, serviceBrands } from '~/data/products';

// ---------------------------------------------------------------------------
// Schema.org — ItemList for the flat product catalog
// ---------------------------------------------------------------------------
const productCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Surgiquip Solutions Product Catalog',
  description:
    'Surgical equipment catalog — tables, lights, equipment booms, and OR integration systems. Authorized Skytron dealer for Southeast Texas.',
  url: `${site.url}/products`,
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${site.url}${p.href}`,
    name: p.name,
    item: {
      '@type': 'Product',
      name: p.name,
      description: p.tagline,
      image: `${site.url}${p.image}`,
      brand: { '@type': 'Brand', name: p.brand },
      offers: {
        '@type': 'Offer',
        seller: { '@id': `${site.url}#organization` },
        areaServed: 'Southeast Texas',
        availability: 'https://schema.org/InStock',
      },
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${site.url}/products` },
  ],
};
---
<BaseLayout
  title="Medical Equipment Catalog | Surgiquip Solutions"
  description="Browse surgical tables, lights, booms, and OR integration from Skytron and HSI. Authorized dealer for Southeast Texas hospitals and surgery centers since 1983."
  schema={[productCatalogSchema, breadcrumbSchema]}
>
  <!-- ── Hero — Compact, store-like ── -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-14 md:py-16">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Surgiquip</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Products</span>
      </nav>
      <h1 class="max-w-3xl font-display text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Equipment Catalog
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/80">
        Surgical tables, lights, booms, OR integration, and more — from Skytron, HSI, and the brands we service. Browse, filter, and find what your facility needs.
      </p>
    </div>
  </section>

  <!-- ── Filterable Product Grid ── -->
  <ProductCatalog
    products={products}
    categories={productCategories}
    brands={brands}
  />

  <!-- ── Brands We Service (compact) ── -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">Also Serviced</div>
            <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Brands we service but don't sell</h2>
            <p class="mt-2 text-sm text-[var(--color-text-muted)]">
              Our technicians also service equipment from these manufacturers. Can't find your brand? Call us.
            </p>
          </div>
          <a href="/quote" class="btn-primary shrink-0 text-sm">Request Service Quote</a>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {serviceBrands.map((brand) => (
            <div class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-alt)] px-4 py-1.5 text-sm font-semibold text-[var(--color-navy)]">
              {brand}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Need Help Choosing Equipment?"
    subhead="Tell us about your facility — room count, specialties, and budget. Our team will recommend the right configuration and prepare a custom quote."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel={`Call ${site.phone}`}
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
