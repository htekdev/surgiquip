---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductCatalog from '~/components/ProductCatalog.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

// ---------------------------------------------------------------------------
// Visual product catalog — category-first layout (inspired by IMS-style grid)
// Lets hospital purchasing teams quickly identify what they need at a glance.
// ---------------------------------------------------------------------------
const productCategories = [
  {
    name: 'Surgical Tables',
    href: '/products/skytron#tables',
    image: '/images/products/surgical-table.webp',
    alt: 'Skytron surgical table in an operating room — 6700B multi-specialty platform',
    description: 'Multi-specialty platforms from the flagship 6700B to the imaging-optimized 6701 and cost-effective 3600 series.',
    badge: 'Skytron',
  },
  {
    name: 'Surgical Lights',
    href: '/products/skytron#lights',
    image: '/images/products/surgical-light.webp',
    alt: 'Skytron Aurora LED surgical light — CRI 97+ operating room illumination',
    description: 'Aurora LED (CRI 97+), Stellar, AR24 birthing, and Mini Argos exam lights for every care environment.',
    badge: 'Skytron',
  },
  {
    name: 'Equipment Booms',
    href: '/products/skytron#booms',
    image: '/images/products/equipment-boom.webp',
    alt: 'Skytron Center Mount Boom system — ceiling-mounted OR equipment management',
    description: 'Center Mount ceiling booms with integrated gas, electrical, data, and AV routing for surgical suites.',
    badge: 'Skytron',
  },
  {
    name: 'OR Integration',
    href: '/products/skytron#or-integration',
    image: '/images/products/or-integration.webp',
    alt: 'SkyVision OR integration system — 4K AV switching and unified room control',
    description: 'SkyVision 4K AV switching, display routing, and unified room control for hybrid and robotic ORs.',
    badge: 'Skytron',
  },
];

const partnerBrands = [
  {
    name: 'Skytron',
    href: '/products/skytron',
    eyebrow: 'Primary Partner',
    summary: 'Surgical tables, lights, booms, OR integration — full line available.',
    detail:
      'The gold standard in surgical tables, lights, and equipment booms for operating rooms. As the authorized Skytron dealer for Southeast Texas, Surgiquip provides the full product line including surgical tables, surgical lighting systems, and ceiling-mount equipment booms.',
    badge: 'Authorized Skytron Dealer',
    highlight: true,
  },
  {
    name: 'HSI Hospital Systems',
    href: '/products/hsi',
    eyebrow: 'Partner Brand',
    summary: 'Boom systems, OR furniture, patient care equipment.',
    detail:
      'HSI equips surgical environments with boom systems, operating room furniture, and patient care equipment designed for workflow efficiency and long-term durability.',
    badge: 'Sales + service support',
  },
] as const;

const serviceBrands = ['Steris', 'Stryker', 'Berchtold', 'Maquet', 'Trumpf'] as const;

// ---------------------------------------------------------------------------
// Schema.org — ItemList for product categories + brand list
// ---------------------------------------------------------------------------
const productCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Surgiquip Solutions Product Catalog',
  description:
    'Surgical equipment categories available from Surgiquip Solutions — surgical tables, lights, equipment booms, and OR integration systems. Authorized Skytron dealer for Southeast Texas.',
  url: `${site.url}/products`,
  numberOfItems: productCategories.length,
  itemListElement: productCategories.map((cat, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${site.url}${cat.href}`,
    name: cat.name,
    item: {
      '@type': 'Product',
      name: cat.name,
      description: cat.description,
      image: `${site.url}${cat.image}`,
      brand: { '@type': 'Brand', name: 'Skytron' },
      offers: {
        '@type': 'Offer',
        seller: { '@id': `${site.url}#organization` },
        areaServed: 'Southeast Texas',
        availability: 'https://schema.org/InStock',
      },
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${site.url}/products` },
  ],
};
---
<BaseLayout
  title="Medical Equipment Houston | Surgiquip Solutions"
  description="Surgical tables, lights, booms, and OR integration from Skytron — authorized dealer for Southeast Texas. Browse our full product catalog. Serving hospitals since 1983."
  schema={[productCatalogSchema, breadcrumbSchema]}
>
  <!-- ── Hero ── -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Surgiquip</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Products</span>
      </nav>
      <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-bold tracking-[0.24em] uppercase text-white/80">
        Equipment Catalog
      </div>
      <h1 class="mt-5 max-w-4xl font-display text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl">
        Surgical Equipment for Every OR
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-white/85 md:text-xl">
        Browse our full product catalog — surgical tables, lights, equipment booms, and OR integration systems from Skytron. Authorized dealer for Southeast Texas since 1983.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#catalog" class="btn-primary">Browse Equipment</a>
        <a href="/quote" class="inline-flex items-center gap-2 rounded-md border border-white/30 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
          Request a Quote
        </a>
      </div>
    </div>
  </section>

  <!-- ── Quick-nav badge bar ── -->
  <section class="bg-[var(--color-surface-alt)] border-b border-[var(--color-border)]">
    <div class="container-x py-4">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)]">Jump to:</span>
        {productCategories.map((cat) => (
          <a
            href={cat.href}
            class="rounded-full border border-[var(--color-border)] bg-white px-4 py-1.5 text-sm font-semibold text-[var(--color-navy)] transition hover:border-[var(--color-blue)] hover:text-[var(--color-blue)]"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Visual Product Catalog Grid ── -->
  <div id="catalog">
    <ProductCatalog categories={productCategories} />
  </div>

  <!-- ── Skytron Featured Partner ── -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
        <div class="rounded-2xl border border-[var(--color-blue)] bg-white p-8 shadow-sm md:p-10">
          <div class="flex flex-wrap items-center gap-3">
            <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)]">Primary Partner</div>
            <div class="rounded-full bg-[var(--color-surface-alt)] px-3 py-1 text-xs font-semibold text-[var(--color-navy)]">
              Authorized Skytron Dealer
            </div>
          </div>
          <h2 class="mt-4 font-display text-3xl font-bold text-[var(--color-navy)] md:text-4xl">Skytron</h2>
          <p class="mt-5 text-lg leading-relaxed text-[var(--color-text-muted)]">
            The gold standard in surgical tables, lights, and equipment booms for operating rooms. As the authorized Skytron dealer for Southeast Texas, Surgiquip provides the full product line — including surgical tables, surgical lighting systems, and ceiling-mount equipment booms.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {productCategories.map((cat) => (
              <a href={cat.href} class="flex items-center gap-3 rounded-xl bg-[var(--color-surface-alt)] p-4 transition hover:bg-[var(--color-navy)]/5">
                <img src={cat.image} alt="" class="h-12 w-12 rounded-lg object-cover" loading="lazy" decoding="async" />
                <div>
                  <div class="text-sm font-semibold text-[var(--color-navy)]">{cat.name}</div>
                  <div class="text-xs text-[var(--color-text-muted)]">View models →</div>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/products/skytron" class="btn-primary text-sm">View Full Skytron Line</a>
            <a href="/quote" class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-semibold text-[var(--color-navy)] transition hover:border-[var(--color-navy)]">
              Request Equipment Quote
            </a>
          </div>
        </div>

        <aside class="rounded-2xl border border-[var(--color-border)] bg-white p-8">
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)]">Why It Matters</div>
          <h3 class="mt-3 font-display text-2xl font-bold text-[var(--color-navy)]">Factory-backed guidance, local accountability</h3>
          <div class="mt-6 space-y-5 text-sm leading-relaxed text-[var(--color-text-muted)]">
            <div>
              <div class="font-semibold text-[var(--color-navy)]">Authorized representation</div>
              <p class="mt-1">Your equipment planning, quoting, and follow-up support comes through an established local partner — not a distant distributor.</p>
            </div>
            <div>
              <div class="font-semibold text-[var(--color-navy)]">Project-ready product mix</div>
              <p class="mt-1">From one-room upgrades to multi-suite OR projects, Surgiquip can align equipment selection with installation and service realities.</p>
            </div>
            <div>
              <div class="font-semibold text-[var(--color-navy)]">Service beyond the sale</div>
              <p class="mt-1">Need an unsupported brand serviced? Our team also works on most major surgical equipment manufacturers across the region.</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ── Partner Brand Cards ── -->
  <section class="container-x py-16">
    <div class="max-w-3xl mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Partner Brands</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Equipment lines we represent</h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Each brand page highlights the equipment categories Surgiquip actively supports today. Start with Skytron for flagship OR equipment.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {partnerBrands.map((brand) => (
        <article class={`rounded-2xl border p-7 transition hover:-translate-y-0.5 hover:shadow-md ${brand.highlight ? 'border-[var(--color-blue)] bg-white shadow-sm' : 'border-[var(--color-border)] bg-white'}`}>
          <div class="flex flex-wrap items-center gap-3">
            <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)]">{brand.eyebrow}</div>
            <div class="rounded-full bg-[var(--color-surface-alt)] px-3 py-1 text-xs font-semibold text-[var(--color-navy)]">{brand.badge}</div>
          </div>
          <h3 class="mt-4 font-display text-2xl font-bold text-[var(--color-navy)]">{brand.name}</h3>
          <p class="mt-3 font-semibold text-[var(--color-navy)]">{brand.summary}</p>
          <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-muted)]">{brand.detail}</p>
          <a href={brand.href} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-blue)] hover:underline">
            View brand page
            <svg class="h-4 w-4" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 6h7M6 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- ── Brands We Service ── -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 md:p-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-3xl">
            <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Brands We Service</div>
            <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Support beyond the brands we sell</h2>
            <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
              Surgiquip also services equipment from Steris, Stryker, Berchtold, Maquet, and Trumpf. Can't find your brand? We service most major surgical equipment manufacturers.
            </p>
          </div>
          <a href="/quote" class="btn-primary shrink-0">Request Equipment Quote</a>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          {serviceBrands.map((brand) => (
            <div class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-alt)] px-4 py-2 text-sm font-semibold text-[var(--color-navy)]">
              {brand}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Request Equipment Quote"
    subhead="Tell us what your facility is planning, replacing, or expanding. We'll help you evaluate the right surgical equipment partner and scope the next step."
    primaryLabel="Request Equipment Quote"
    primaryHref="/quote"
    secondaryLabel={`Call ${site.phone}`}
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
