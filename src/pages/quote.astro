---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Request a Quote"
  description="Request a quote for medical equipment, service, repair, or OR installation. Response within one business day."
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-16">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70">Request Quote</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3 text-white">Get a Quote</h1>
      <p class="mt-4 text-lg text-white/85 max-w-2xl">Tell us what you need. We respond within one business day.</p>
    </div>
  </section>

  <section class="container-x py-16 max-w-2xl">
    <form action="/api/quote-request" method="POST" class="space-y-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="space-y-1">
          <label for="quote-name" class="block text-sm font-semibold text-[var(--color-navy)]">
            Full Name <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="quote-name"
            name="name"
            required
            autocomplete="name"
            placeholder="Jane Smith"
            class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
          />
        </div>
        <div class="space-y-1">
          <label for="quote-email" class="block text-sm font-semibold text-[var(--color-navy)]">
            Email Address <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="quote-email"
            name="email"
            required
            autocomplete="email"
            placeholder="jane@hospital.org"
            class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
          />
        </div>
      </div>
      <div class="space-y-1">
        <label for="quote-organization" class="block text-sm font-semibold text-[var(--color-navy)]">
          Facility / Organization <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="quote-organization"
          name="organization"
          required
          autocomplete="organization"
          placeholder="Memorial Hermann Hospital"
          class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
        />
      </div>
      <div class="space-y-1">
        <label for="quote-phone" class="block text-sm font-semibold text-[var(--color-navy)]">
          Phone <span class="text-xs font-normal text-[var(--color-text-muted)]">(optional)</span>
        </label>
        <input
          type="tel"
          id="quote-phone"
          name="phone"
          autocomplete="tel"
          placeholder="(713) 555-0100"
          class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
        />
      </div>
      <div class="space-y-1">
        <label for="quote-interest" class="block text-sm font-semibold text-[var(--color-navy)]">
          Area of Interest <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <select
          id="quote-interest"
          name="interest"
          required
          class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
        >
          <option value="">Select one…</option>
          <option>Equipment Sales — Skytron</option>
          <option>Equipment Sales — Other</option>
          <option>Service &amp; Repair</option>
          <option>OR Installation / Integration</option>
          <option>Preventive Maintenance Program</option>
          <option>Other / Not Sure</option>
        </select>
      </div>
      <div class="space-y-1">
        <label for="quote-message" class="block text-sm font-semibold text-[var(--color-navy)]">
          Project Details <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <textarea
          id="quote-message"
          name="message"
          required
          rows="6"
          placeholder="Tell us about your project, timeline, and any equipment specifics…"
          class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none focus:ring-2 focus:ring-[var(--color-blue)]/20"
        ></textarea>
      </div>
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <button type="submit" class="btn-primary w-full md:w-auto">Submit Request</button>
      <p class="text-xs text-[var(--color-text-muted)]">
        By submitting, you agree to our <a href="/privacy">Privacy Policy</a>. We respond within one business day.
      </p>
    </form>
  </section>
</BaseLayout>
