---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Request a Quote"
  description="Request a quote for medical equipment, service, repair, or OR installation. Response within one business day."
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-16">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70">Request Quote</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3 text-white">Get a Quote</h1>
      <p class="mt-4 text-lg text-white/85 max-w-2xl">Tell us what you need. We respond within one business day.</p>
    </div>
  </section>

  <section class="container-x py-16 max-w-2xl">
    <form action="/api/quote-request" method="POST" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <input type="text" name="name" required placeholder="Your name *" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
        <input type="email" name="email" required placeholder="Email *" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
      </div>
      <input type="text" name="organization" required placeholder="Facility / Organization *" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
      <input type="tel" name="phone" placeholder="Phone (optional)" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
      <select name="interest" required class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none">
        <option value="">What are you interested in? *</option>
        <option>Equipment Sales — Skytron</option>
        <option>Equipment Sales — Other</option>
        <option>Service & Repair</option>
        <option>OR Installation / Integration</option>
        <option>Preventive Maintenance Program</option>
        <option>Other / Not Sure</option>
      </select>
      <textarea name="message" required rows="6" placeholder="Tell us more about your project, timeline, and any equipment specifics *" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none"></textarea>
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <button type="submit" class="btn-primary w-full md:w-auto">Submit Request</button>
      <p class="text-xs text-[var(--color-text-muted)]">By submitting, you agree to our <a href="/privacy">Privacy Policy</a>. We respond within one business day.</p>
    </form>
  </section>
</BaseLayout>
