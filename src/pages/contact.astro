---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const contactSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    url: `${site.url}/contact`,
    mainEntity: { '@id': `${site.url}#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${site.url}#organization`,
    name: site.brand,
    url: site.url,
    telephone: site.phone,
    faxNumber: site.fax,
    email: site.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.address.street,
      addressLocality: site.address.city,
      addressRegion: site.address.region,
      postalCode: site.address.postalCode,
      addressCountry: site.address.country,
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '07:30',
        closes: '16:30',
      },
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: site.phone,
      contactType: 'sales',
      areaServed: 'US-TX',
      availableLanguage: 'English',
      hoursAvailable: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '07:30',
        closes: '16:30',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: `${site.url}/contact` },
    ],
  },
];

// Google Maps embed URL for 10653 Kinghurst Drive, Houston TX 77099
const mapsEmbedUrl =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3467.0!2d-95.5686!3d29.6712!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8640e4b8c1234567%3A0xabcdef1234567890!2s10653+Kinghurst+Dr%2C+Houston%2C+TX+77099!5e0!3m2!1sen!2sus!4v1720000000000';
---
<BaseLayout
  title="Contact Surgiquip Solutions | Houston, TX (713) 681-6362"
  description="Contact Surgiquip Solutions in Houston, TX. Phone (713) 681-6362. Mon–Fri 7:30am–4:30pm. Medical equipment sales, service, and OR installation for Southeast Texas."
  schema={contactSchema}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-16">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Contact</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70">Contact</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3 text-white">Let's Talk Equipment.</h1>
      <p class="mt-4 text-lg text-white/85 max-w-2xl">Whether you need a quote, a service visit, or a turnkey OR install — our team responds within one business day.</p>
    </div>
  </section>

  <!-- Contact Info + Form -->
  <section class="container-x py-16 grid gap-10 lg:grid-cols-2">
    <div>
      <h2 class="text-2xl font-bold text-[var(--color-navy)]">Reach Us Directly</h2>
      <ul class="mt-6 space-y-5 text-[var(--color-text)]">
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-surface-alt)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-navy)]" aria-hidden="true">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
          </span>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Phone</div>
            <a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] hover:underline font-medium">{site.phone}</a>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">{site.hours}</div>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-surface-alt)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-navy)]" aria-hidden="true">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          </span>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Email</div>
            <a href={`mailto:${site.email}`} class="text-[var(--color-blue)] hover:underline">{site.email}</a>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-surface-alt)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-navy)]" aria-hidden="true">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </span>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Headquarters</div>
            <address class="not-italic text-[var(--color-text-muted)] text-sm leading-relaxed">
              {site.address.street}<br />
              {site.address.city}, {site.address.region} {site.address.postalCode}
            </address>
            <a
              href="https://maps.google.com/?q=10653+Kinghurst+Dr,+Houston,+TX+77099"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[var(--color-blue)] hover:underline mt-1 inline-block"
            >
              Get Directions →
            </a>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-surface-alt)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-navy)]" aria-hidden="true">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </span>
          <div>
            <div class="font-semibold text-[var(--color-navy)]">Fax</div>
            <div class="text-[var(--color-text-muted)]">{site.fax}</div>
          </div>
        </li>
      </ul>

      <!-- Quick links -->
      <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
        <div class="text-sm font-semibold text-[var(--color-navy)] mb-3">Quick Actions</div>
        <div class="flex flex-wrap gap-3">
          <a href="/quote" class="btn-primary text-sm">Request a Quote</a>
          <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border)] text-sm font-semibold text-[var(--color-navy)] hover:border-[var(--color-navy)] transition">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
            Call Now
          </a>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div>
      <h2 class="text-2xl font-bold text-[var(--color-navy)]">Send a Message</h2>
      <p class="text-sm text-[var(--color-text-muted)] mt-2">Use the quote form for equipment requests, or message us below for general inquiries. We respond within one business day.</p>
      <form action="/api/quote-request" method="POST" class="mt-6 space-y-4" novalidate>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="block text-sm font-medium text-[var(--color-navy)] mb-1">Your Name <span aria-hidden="true">*</span></label>
            <input id="contact-name" type="text" name="name" required autocomplete="name"
              class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none text-[var(--color-text)]" />
          </div>
          <div>
            <label for="contact-email" class="block text-sm font-medium text-[var(--color-navy)] mb-1">Email <span aria-hidden="true">*</span></label>
            <input id="contact-email" type="email" name="email" required autocomplete="email"
              class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none text-[var(--color-text)]" />
          </div>
        </div>
        <div>
          <label for="contact-org" class="block text-sm font-medium text-[var(--color-navy)] mb-1">Facility / Organization</label>
          <input id="contact-org" type="text" name="organization" autocomplete="organization"
            class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none text-[var(--color-text)]" />
        </div>
        <div>
          <label for="contact-phone" class="block text-sm font-medium text-[var(--color-navy)] mb-1">Phone <span class="text-[var(--color-text-muted)] font-normal">(optional)</span></label>
          <input id="contact-phone" type="tel" name="phone" autocomplete="tel"
            class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none text-[var(--color-text)]" />
        </div>
        <div>
          <label for="contact-message" class="block text-sm font-medium text-[var(--color-navy)] mb-1">Message <span aria-hidden="true">*</span></label>
          <textarea id="contact-message" name="message" required rows="5"
            class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none text-[var(--color-text)]"></textarea>
        </div>
        <!-- Source identifier -->
        <input type="hidden" name="source" value="contact" />
        <!-- Honeypot -->
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        <button type="submit" class="btn-primary w-full md:w-auto">Send Message</button>
      </form>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <h2 class="text-xl font-bold text-[var(--color-navy)] mb-4">Our Location</h2>
      <div class="rounded-xl overflow-hidden border border-[var(--color-border)] shadow-sm" style="height: 360px;">
        <iframe
          title="Surgiquip Solutions location — 10653 Kinghurst Drive, Houston TX 77099"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3465.3956!2d-95.5752!3d29.6775!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8640e4b7c1234567%3A0x9876543210abcdef!2s10653+Kinghurst+Dr%2C+Houston%2C+TX+77099!5e0!3m2!1sen!2sus!4v1719878400000!5m2!1sen!2sus"
          width="100%"
          height="360"
          style="border: 0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="mt-3 text-sm text-[var(--color-text-muted)]">
        10653 Kinghurst Drive, Houston, TX 77099 &middot;
        <a href="https://maps.google.com/?q=10653+Kinghurst+Dr,+Houston,+TX+77099" target="_blank" rel="noopener noreferrer" class="text-[var(--color-blue)] hover:underline">Open in Google Maps</a>
      </p>
    </div>
  </section>

  <CTASection
    heading="Need Urgent Service?"
    subhead="Equipment down? Call us directly. Factory-trained technicians, same-day response when available."
    primaryLabel={`Call ${site.phone}`}
    primaryHref={`tel:${site.phoneE164}`}
    secondaryLabel="Request Quote Online"
    secondaryHref="/quote"
  />
</BaseLayout>
