---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/data/site';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: `${site.url}/contact`,
  mainEntity: { '@id': `${site.url}#organization` },
};
---
<BaseLayout
  title="Contact Surgiquip Solutions"
  description="Contact Surgiquip Solutions in Houston, TX. Phone (713) 681-6362. Hours Mon-Fri 7:30am-4:30pm. Medical equipment sales, service, and OR installation."
  schema={contactSchema}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-16">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70">Contact</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3 text-white">Let's Talk Equipment.</h1>
      <p class="mt-4 text-lg text-white/85 max-w-2xl">Whether you need a quote, a service visit, or a turnkey OR install — our team responds within one business day.</p>
    </div>
  </section>

  <section class="container-x py-16 grid gap-10 lg:grid-cols-2">
    <div>
      <h2 class="text-2xl font-bold text-[var(--color-navy)]">Reach Us Directly</h2>
      <ul class="mt-6 space-y-4 text-[var(--color-text)]">
        <li class="flex items-start gap-3"><span class="text-xl">📞</span><div><div class="font-semibold">Phone</div><a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] hover:underline">{site.phone}</a></div></li>
        <li class="flex items-start gap-3"><span class="text-xl">📠</span><div><div class="font-semibold">Fax</div><div>{site.fax}</div></div></li>
        <li class="flex items-start gap-3"><span class="text-xl">✉️</span><div><div class="font-semibold">Email</div><a href={`mailto:${site.email}`} class="text-[var(--color-blue)] hover:underline">{site.email}</a></div></li>
        <li class="flex items-start gap-3"><span class="text-xl">📍</span><div><div class="font-semibold">Headquarters</div><div>{site.address.street}<br/>{site.address.city}, {site.address.region} {site.address.postalCode}</div></div></li>
        <li class="flex items-start gap-3"><span class="text-xl">🕐</span><div><div class="font-semibold">Hours</div><div>{site.hours}</div></div></li>
      </ul>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-[var(--color-navy)]">Send a Message</h2>
      <p class="text-sm text-[var(--color-text-muted)] mt-2">Use the quote form for equipment requests, or message us below for general inquiries.</p>
      <form action="/api/quote-request" method="POST" class="mt-6 space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" name="name" required placeholder="Your name" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
          <input type="email" name="email" required placeholder="Email" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
        </div>
        <input type="text" name="organization" placeholder="Facility / Organization" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
        <input type="tel" name="phone" placeholder="Phone (optional)" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none" />
        <textarea name="message" required rows="5" placeholder="How can we help?" class="w-full rounded-md border border-[var(--color-border)] px-4 py-3 focus:border-[var(--color-blue)] focus:outline-none"></textarea>
        <!-- Honeypot -->
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        <button type="submit" class="btn-primary w-full md:w-auto">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>
