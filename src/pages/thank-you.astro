---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout title="Thank You" description="Thanks for reaching out — we'll respond within one business day." noindex>
  <section class="container-x py-24 text-center">
    <div class="text-6xl mb-4">✅</div>
    <h1 class="text-4xl font-bold text-[var(--color-navy)]">Thank You</h1>
    <p class="mt-4 text-lg text-[var(--color-text-muted)] max-w-xl mx-auto">Your message is on its way to our team. We respond within one business day.</p>
    <a href="/" class="btn-primary mt-8 inline-flex">Back to Home</a>
  </section>
</BaseLayout>
