---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/data/site';
const updated = 'June 25, 2026';
---
<BaseLayout
  title="Privacy Policy | Surgiquip Solutions"
  description="Surgiquip Solutions, Inc. Privacy Policy — how we collect, use, and protect your information."
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-16">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Privacy Policy</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Legal</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white">Privacy Policy</h1>
      <p class="mt-4 text-white/70 text-sm">Last updated: {updated}</p>
    </div>
  </section>

  <section class="container-x py-16 max-w-3xl">
    <div class="prose prose-slate max-w-none space-y-10 text-[var(--color-text)]">

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Introduction</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Surgiquip Solutions, Inc. ("Surgiquip," "we," "us," or "our") respects your privacy and is committed to protecting the personal information you share with us. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit <strong>surgiquip.com</strong> (the "Site") or contact us about our medical equipment sales, service, repair, and OR installation services.
        </p>
        <p class="text-[var(--color-text-muted)] leading-relaxed mt-3">
          By using the Site or submitting a contact or quote form, you agree to the terms of this Privacy Policy. If you do not agree, please do not use the Site.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Information We Collect</h2>
        <h3 class="font-semibold text-[var(--color-navy)] mb-2">Information You Provide</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          When you fill out a contact or quote request form on the Site, we collect:
        </p>
        <ul class="list-disc pl-6 mt-2 space-y-1 text-[var(--color-text-muted)]">
          <li>Your name and job title</li>
          <li>Facility or organization name</li>
          <li>Email address and phone number</li>
          <li>Details about the equipment, service, or project you are inquiring about</li>
          <li>Any other information you voluntarily include in your message</li>
        </ul>
        <h3 class="font-semibold text-[var(--color-navy)] mb-2 mt-6">Automatically Collected Information</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          When you visit the Site, our hosting provider and analytics tools may automatically collect:
        </p>
        <ul class="list-disc pl-6 mt-2 space-y-1 text-[var(--color-text-muted)]">
          <li>IP address and approximate geographic location (city/state)</li>
          <li>Browser type and operating system</li>
          <li>Pages visited, time on site, and referral URL</li>
          <li>Device type (desktop, mobile, tablet)</li>
        </ul>
        <p class="text-[var(--color-text-muted)] leading-relaxed mt-3">
          We use Google Analytics 4 to collect this data in aggregate and anonymized form to understand how visitors use the Site. Google Analytics data is governed by <a href="https://policies.google.com/privacy" class="text-[var(--color-blue)] hover:underline" target="_blank" rel="noopener noreferrer">Google's Privacy Policy</a>.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">How We Use Your Information</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">We use the information we collect to:</p>
        <ul class="list-disc pl-6 mt-2 space-y-1 text-[var(--color-text-muted)]">
          <li>Respond to your inquiry, quote request, or service call</li>
          <li>Provide pricing, availability, and technical information about our products and services</li>
          <li>Schedule site visits, installations, or service appointments</li>
          <li>Send follow-up communications related to your inquiry (not marketing)</li>
          <li>Improve the Site and our services based on aggregate usage data</li>
          <li>Comply with applicable laws and regulations</li>
        </ul>
        <p class="text-[var(--color-text-muted)] leading-relaxed mt-4 font-medium">
          We do not send unsolicited marketing emails or add you to any mailing list without your explicit consent.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">How We Share Your Information</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          We do not sell, trade, or rent your personal information to third parties. We may share your information only in the following limited circumstances:
        </p>
        <ul class="list-disc pl-6 mt-2 space-y-1 text-[var(--color-text-muted)]">
          <li><strong>Service providers:</strong> We use Resend (email delivery) to route form submissions to our staff. These providers process data only on our behalf and are bound by confidentiality obligations.</li>
          <li><strong>Manufacturer partners:</strong> If your inquiry relates to Skytron or other partner equipment, we may share relevant technical details with the manufacturer's authorized support team to provide accurate quotes or service.</li>
          <li><strong>Legal requirements:</strong> We may disclose information if required by law, court order, or to protect our legal rights.</li>
        </ul>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Data Retention</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          We retain inquiry and quote request records for up to <strong>3 years</strong> to support ongoing service relationships, warranty tracking, and business records. You may request deletion of your records at any time by contacting us at the address below.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Cookies</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          The Site uses first-party and third-party cookies for analytics (Google Analytics 4). These cookies collect anonymized data about how visitors use the Site. You may disable cookies through your browser settings; however, some Site features may not function properly without them.
        </p>
        <p class="text-[var(--color-text-muted)] leading-relaxed mt-3">
          We do not use advertising cookies, remarketing pixels, or cross-site tracking.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Security</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          The Site is served over HTTPS (TLS encryption). Form submissions are transmitted securely. We take reasonable technical and organizational measures to protect your information from unauthorized access, loss, or misuse. No method of transmission over the internet is 100% secure, and we cannot guarantee absolute security.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Your Rights</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">You have the right to:</p>
        <ul class="list-disc pl-6 mt-2 space-y-1 text-[var(--color-text-muted)]">
          <li>Request a copy of the personal information we hold about you</li>
          <li>Request correction of inaccurate information</li>
          <li>Request deletion of your personal information (subject to legal retention requirements)</li>
          <li>Opt out of any future communications from us</li>
        </ul>
        <p class="text-[var(--color-text-muted)] leading-relaxed mt-3">
          To exercise any of these rights, contact us at <a href={`mailto:${site.email}`} class="text-[var(--color-blue)] hover:underline">{site.email}</a> or by phone at <a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] hover:underline">{site.phone}</a>.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Children's Privacy</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          The Site is intended for healthcare professionals and business contacts only. We do not knowingly collect personal information from individuals under the age of 18. If we become aware that a minor has submitted personal information, we will delete it promptly.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-4">Changes to This Policy</h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          We may update this Privacy Policy from time to time to reflect changes in our practices or applicable law. We will post the updated policy on this page with a revised "Last updated" date. We encourage you to review this page periodically.
        </p>
      </div>

      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-6">
        <h2 class="font-display text-xl font-bold text-[var(--color-navy)] mb-3">Contact Us</h2>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
          If you have questions about this Privacy Policy or how we handle your information, please contact:
        </p>
        <ul class="mt-3 space-y-1 text-sm text-[var(--color-text-muted)]">
          <li><strong class="text-[var(--color-navy)]">Surgiquip Solutions, Inc.</strong></li>
          <li>{site.address.street}, {site.address.city}, {site.address.region} {site.address.postalCode}</li>
          <li>Phone: <a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] hover:underline">{site.phone}</a></li>
          <li>Email: <a href={`mailto:${site.email}`} class="text-[var(--color-blue)] hover:underline">{site.email}</a></li>
        </ul>
      </div>

    </div>
  </section>
</BaseLayout>

