---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${site.url}/about` },
    { '@type': 'ListItem', position: 3, name: 'Accreditation', item: `${site.url}/about/accreditation` },
  ],
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  '@id': `${site.url}/#organization`,
  name: site.brand,
  url: site.url,
  award: [
    'BBB Torch Award for Ethics 2014',
    'BBB Torch Award for Ethics 2015',
    'BBB Torch Award for Ethics 2016',
    'BBB Torch Award for Ethics 2017',
    'BBB Torch Award for Ethics 2018',
    'BBB A+ Rating — 16 consecutive years',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'Texas DSHS Device Distributor License',
      recognizedBy: { '@type': 'Organization', name: 'Texas Department of State Health Services' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: 'Texas DSHS Salvage Establishment License',
      recognizedBy: { '@type': 'Organization', name: 'Texas Department of State Health Services' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'certification',
      name: 'Texas Certified HUB Vendor',
      recognizedBy: { '@type': 'Organization', name: 'Texas Comptroller of Public Accounts' },
    },
  ],
  memberOf: [
    {
      '@type': 'Organization',
      name: 'Memorial Hermann Integrated Delivery Network',
      description: 'Vital Affiliate — Memorial Hermann IDN',
    },
  ],
};
---
<BaseLayout
  title="Accreditation & Awards | Surgiquip Solutions"
  description="BBB A+ rated. Torch Award for Ethics 2014-2018 (5 consecutive years). Texas Certified HUB Vendor. DSHS-licensed distributor. Authorized Skytron dealer. Factory-certified for Skytron, Midmark, Tuttnauer."
  schema={[breadcrumbSchema, organizationSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/about" class="hover:text-white/90">About</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Accreditation</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Trust & Credentials</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Accredited. Authorized. Trusted.
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Our credentials are earned, not purchased. They represent 43 years of operating to the standards
        that hospitals, surgery centers, and healthcare networks require.
      </p>
    </div>
  </section>

  <!-- ── BBB Torch Award Feature ─────────────────────────────────────────────── -->
  <section class="bg-[var(--color-surface-alt)] py-16 border-b border-[var(--color-border)]">
    <div class="container-x">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center gap-8">
          <div class="shrink-0 flex items-center justify-center w-24 h-24 rounded-full bg-[var(--color-navy)] text-white text-2xl font-display font-bold">
            BBB
          </div>
          <div>
            <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">Highest BBB Honor</div>
            <h2 class="font-display text-2xl md:text-3xl font-bold text-[var(--color-navy)] mb-3">
              Torch Award for Ethics — Five Consecutive Years
            </h2>
            <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
              The BBB Torch Award for Ethics is the highest honor the Better Business Bureau grants to businesses
              in the Greater Houston area. It recognizes companies that demonstrate exceptional standards of ethics,
              integrity, and trust in all business dealings. Surgiquip Solutions earned this distinction five years
              in a row — a record that reflects consistent character, not a one-time result.
            </p>
            <div class="flex flex-wrap gap-2">
              {['2014', '2015', '2016', '2017', '2018'].map((year) => (
                <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-[var(--color-navy)] text-white text-sm font-bold">
                  Torch Award {year}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Credentials Grid ────────────────────────────────────────────────────── -->
  <section class="container-x py-16">
    <div class="text-center mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Authorizations & Licenses</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Every Credential That Matters</h2>
    </div>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {[
        {
          badge: 'BBB A+',
          title: 'Better Business Bureau — A+ Accredited',
          body: 'Surgiquip Solutions holds an A+ rating with the BBB — the highest possible grade, maintained for 16 consecutive years. Zero unresolved complaints. This rating reflects our track record of transparent business practices and our commitment to resolving any issues that arise.',
        },
        {
          badge: 'Authorized',
          title: 'Authorized Skytron Dealer — Southeast Texas',
          body: 'Skytron grants exclusive dealerships to a small number of partners per region. Our authorization for Southeast Texas means direct factory oversight: certified technicians, manufacturer parts, and technical support unavailable to independent distributors.',
        },
        {
          badge: 'Certified',
          title: 'Factory-Certified Technicians',
          body: 'Our service team holds factory certifications from Skytron, Midmark, and Tuttnauer — three distinct manufacturer programs. Each certification requires ongoing training and renewal. Every repair follows OEM procedures with documentation acceptable for Joint Commission surveys.',
        },
        {
          badge: 'Texas HUB',
          title: 'Texas Certified HUB Vendor',
          body: 'Surgiquip Solutions is a Texas-certified Historically Underutilized Business (HUB) vendor. This state certification allows Texas public health systems, university medical centers, and government hospitals to count Surgiquip toward their HUB procurement goals — expanding our reach in public sector healthcare.',
        },
        {
          badge: 'DSHS Licensed',
          title: 'Texas DSHS: Device Distributor License',
          body: 'Licensed by the Texas Department of State Health Services as a medical device distributor. This state-level license verifies that our distribution operations meet DSHS standards for handling, storing, and delivering regulated medical equipment across Texas facilities.',
        },
        {
          badge: 'DSHS Licensed',
          title: 'Texas DSHS: Salvage Establishment License',
          body: 'DSHS-licensed salvage establishment — authorizing us to handle, refurbish, and resell medical equipment within Texas regulatory guidelines. This license is critical for used equipment programs and decommissioning services we provide to healthcare facilities.',
        },
        {
          badge: 'Network Affiliate',
          title: 'Vital Affiliate — Memorial Hermann IDN',
          body: 'Surgiquip Solutions holds Vital Affiliate status within the Memorial Hermann Integrated Delivery Network — the largest health system in Southeast Texas. This affiliation reflects a multi-decade, multi-facility supply relationship across more than 10 Memorial Hermann facilities throughout Greater Houston.',
        },
      ].map((item) => (
        <div class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition">
          <div class="mb-4">
            <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-blue)] text-white mb-2">{item.badge}</span>
            <h3 class="font-bold text-[var(--color-navy)] text-base leading-tight">{item.title}</h3>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x max-w-3xl text-center">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Compliance Documentation</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Survey-Ready Documentation, Every Time</h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Every service visit, PM completion, and installation generates documentation formatted for Joint Commission and CMS requirements. Our clients don't scramble during surveys — their records are organized and current.
      </p>
      <div class="mt-8 grid grid-cols-2 md:grid-cols-3 gap-4 text-center">
        {[
          ['Joint Commission', 'EC.02.04.01 compliance'],
          ['CMS', 'Conditions of Participation'],
          ['NFPA 99', 'Medical gas compliance'],
        ].map(([org, note]) => (
          <div class="p-4 bg-white rounded-lg border border-[var(--color-border)]">
            <div class="font-bold text-[var(--color-navy)] text-sm">{org}</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">{note}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Questions About Our Credentials?"
    subhead={`Call us at ${site.phone} or send an email to ${site.email}. We can provide reference letters, authorization documentation, or BBB verification on request.`}
    primaryLabel="Contact Us"
    primaryHref="/contact"
    secondaryLabel={`Call ${site.phone}`}
  />
</BaseLayout>
