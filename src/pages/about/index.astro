---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: `${site.url}/about`,
  mainEntity: { '@id': `${site.url}#organization` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${site.url}/about` },
  ],
};

const milestones = [
  { year: '1983', event: 'Founded in Houston, TX. Started with surgical table sales and service for local hospitals.' },
  { year: '1990s', event: 'Expanded service territory across Southeast Texas. Grew to serve hospital networks and ASCs.' },
  { year: '2000s', event: 'Became authorized Skytron dealer for Southeast Texas. First hybrid OR installations.' },
  { year: '2010s', event: 'Completed 500+ facility milestones. Expanded OR integration and video system capabilities.' },
  { year: '2020s', event: 'Serving Texas\'s largest hospital systems. $30K–$2M project range. BBB A+ accredited.' },
  { year: 'Today', event: site.yearsInBusiness + ' years strong. Same commitment. Same team. Dedicated to Excellence.' },
];

const values = [
  {
    icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" fill="none"/>',
    title: 'Factory-Grade Standards',
    desc: 'Every installation and repair follows manufacturer specifications. No shortcuts. We\'re factory-authorized for a reason.',
  },
  {
    icon: '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
    title: 'Long-Term Relationships',
    desc: '43 years in one market means clients we\'ve served for decades. We\'re invested in the long-term health of your facility.',
  },
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Accountability',
    desc: 'We don\'t disappear after the sale. Rapid response during business hours is part of who we are — not a premium add-on.',
  },
  {
    icon: '<path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
    title: 'BBB A+ Integrity',
    desc: 'Our A+ Better Business Bureau accreditation reflects how we operate: transparent pricing and honest assessments.',
  },
];
---
<BaseLayout
  title="About Surgiquip Solutions | 43 Years of Houston Healthcare"
  description="43 years serving Texas healthcare. Authorized Skytron dealer, BBB A+ — OR equipment sales, installation, and service for Southeast Texas facilities."
  schema={[aboutSchema, breadcrumbSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">About Us</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Dedicated to Excellence<br/>Since {site.established}
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        {site.yearsInBusiness} years. One mission. A Houston-based family of medical equipment professionals who believe every OR deserves the best — and every client deserves a team that shows up.
      </p>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Our Story</div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
          Houston's Longest-Standing OR Equipment Partner
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Surgiquip Solutions, Inc. was founded in Houston in 1983 with a simple purpose: help Texas hospitals and surgery centers get the best surgical equipment and keep it running. Over four decades, that purpose hasn't changed — only our capabilities have grown.
        </p>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Today, we're the exclusive authorized Skytron dealer for South Texas and Southeast Texas — the gold standard partnership in the surgical equipment industry. Our team has installed and serviced equipment across 500+ healthcare facilities, from single-room surgery centers to major Houston hospital systems.
        </p>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Our clients don't come to us for transactions. They come because when something goes wrong at 5:00 AM before a scheduled OR day, they know we'll answer. That trust is the foundation of everything we do.
        </p>
        <div class="mt-8 flex flex-wrap gap-6">
          {[
            [site.yearsInBusiness + '+', 'Years in business'],
            ['500+', 'Facilities served'],
            ['A+', 'BBB rating'],
          ].map(([val, label]) => (
            <div class="text-center">
              <div class="font-display text-3xl font-bold text-[var(--color-navy)]">{val}</div>
              <div class="text-xs text-[var(--color-text-muted)] mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-5">Company Timeline</div>
        <ol class="space-y-5 relative before:absolute before:left-4 before:top-0 before:bottom-0 before:w-px before:bg-[var(--color-border)]">
          {milestones.map(({ year, event }) => (
            <li class="flex gap-5 pl-10 relative">
              <div class="absolute left-0 top-1 w-8 h-8 rounded-full bg-white border-2 border-[var(--color-blue)] flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></div>
              </div>
              <div>
                <div class="font-bold text-[var(--color-navy)] text-sm">{year}</div>
                <div class="text-sm text-[var(--color-text-muted)] mt-0.5">{event}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Our Values</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What Drives Everything We Do</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {values.map((item) => (
          <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 text-center hover:shadow-md transition">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mx-auto mb-4">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-10 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Our Partners</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Trusted Brands. Authorized Relationships.</h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Our partnerships aren't marketing arrangements — they're operational relationships that give our clients direct access to manufacturer expertise, parts, and support.
        </p>
        <ul class="mt-6 space-y-4">
          {[
            ['Skytron®', 'Exclusive authorized dealer for South Texas and Southeast Texas. Full product line: tables, lights, booms, OR integration.'],
            ['Wassenberg', 'Partner for advanced medical equipment solutions.'],
            ['Infinitus', 'Partner for healthcare technology and equipment.'],
            ['WEG', 'Partner for medical equipment systems.'],
            ['BBB Accredited Business (A+)', 'Voluntarily meets BBB accreditation standards. A+ rating maintained since accreditation.'],
          ].map(([partner, desc]) => (
            <li class="flex gap-4 p-4 bg-[var(--color-surface-alt)] rounded-lg border border-[var(--color-border)]">
              <div class="shrink-0 w-2 h-2 rounded-full bg-[var(--color-blue)] mt-2"></div>
              <div>
                <div class="font-bold text-[var(--color-navy)] text-sm">{partner}</div>
                <div class="text-sm text-[var(--color-text-muted)] mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Headquarters</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Houston, TX — Serving All of Texas</h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Our operations are based in Houston — the medical capital of Texas — with service reach across the state. Most Texas healthcare facilities are within our rapid dispatch radius.
        </p>
        <div class="mt-6 space-y-3 text-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/></svg>
            <div>
              <div class="font-medium text-[var(--color-navy)]">{site.address.street}</div>
              <div class="text-[var(--color-text-muted)]">{site.address.city}, {site.address.region} {site.address.postalCode}</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
            <a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] hover:underline font-medium">{site.phone}</a>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <div class="text-[var(--color-text-muted)]">{site.hours}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Let's Work Together"
    subhead="Whether you need new equipment, a service contract, or an OR build — we're ready. Same team. Same commitment. 43 years running."
    primaryLabel="Get in Touch"
    primaryHref="/contact"
    secondaryLabel={`Call ${site.phone}`}
  />
</BaseLayout>
