---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const {
  title,
  subtitle,
  type,
  facility,
  location,
  value,
  year,
  status,
  equipment,
  scope,
  seoTitle,
  seoDescription,
} = entry.data;

const pageTitle = seoTitle ?? `${title} | Surgiquip Solutions`;
const pageDesc = seoDescription ?? scope;
const slug = entry.id;
const canonicalUrl = `${site.url}/projects/${slug}`;

// Status badge color
const statusColor =
  status === 'Active' || status === 'Ongoing'
    ? 'bg-green-100 text-green-800'
    : 'bg-[var(--color-surface-alt)] text-[var(--color-text-muted)]';

// JSON-LD — Article schema for case study
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: pageDesc,
  author: {
    '@type': 'Organization',
    name: site.brand,
    url: site.url,
  },
  publisher: {
    '@type': 'Organization',
    name: site.brand,
    url: site.url,
  },
  datePublished: `${year}-01-01`,
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  about: {
    '@type': 'Service',
    name: type,
    provider: {
      '@type': 'LocalBusiness',
      name: site.brand,
      telephone: site.phone,
      address: {
        '@type': 'PostalAddress',
        streetAddress: site.address.street,
        addressLocality: site.address.city,
        addressRegion: site.address.region,
        postalCode: site.address.postalCode,
        addressCountry: site.address.country,
      },
    },
  },
};

// Breadcrumb JSON-LD
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.url}/projects` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonical={canonicalUrl}
  schema={[schema, breadcrumbSchema]}
>
  {/* Hero */}
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li><a href="/projects" class="hover:text-white transition">Projects</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li class="text-white/90 truncate max-w-[200px]" aria-current="page">{title}</li>
        </ol>
      </nav>

      {/* Type + Status badges */}
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="inline-block px-3 py-1 text-xs font-bold rounded-full bg-white/20 text-white uppercase tracking-wide">
          {type}
        </span>
        <span class={`inline-block px-3 py-1 text-xs font-bold rounded-full ${status === 'Active' || status === 'Ongoing' ? 'bg-green-400/20 text-green-200' : 'bg-white/10 text-white/70'}`}>
          {status}
        </span>
      </div>

      <h1 class="font-display text-3xl md:text-5xl font-bold text-white leading-tight max-w-3xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl leading-relaxed">{subtitle}</p>

      {/* Meta bar */}
      <div class="mt-8 flex flex-wrap gap-6 text-sm text-white/70 border-t border-white/20 pt-6">
        <div>
          <span class="block text-xs uppercase tracking-widest text-white/50 mb-1">Facility</span>
          <span class="text-white/90 font-medium">{facility}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-widest text-white/50 mb-1">Location</span>
          <span class="text-white/90 font-medium">{location}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-widest text-white/50 mb-1">Project Value</span>
          <span class="text-white/90 font-medium">{value}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-widest text-white/50 mb-1">Year</span>
          <span class="text-white/90 font-medium">{year}</span>
        </div>
      </div>
    </div>
  </section>

  {/* Main content grid */}
  <section class="container-x py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 items-start">

      {/* Case study body */}
      <article class="project-body">
        <Content />
      </article>

      {/* Sidebar */}
      <aside class="space-y-6">

        {/* Equipment list */}
        <div class="bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] p-6">
          <h2 class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-4">Equipment Used</h2>
          <ul class="space-y-2">
            {equipment.map((item) => (
              <li class="flex items-start gap-2 text-sm text-[var(--color-text-muted)]">
                <svg class="w-4 h-4 text-[var(--color-blue)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* CTA card */}
        <div class="bg-[var(--color-navy)] rounded-xl p-6 text-white">
          <h2 class="font-display text-lg font-bold mb-2">Planning a Similar Project?</h2>
          <p class="text-sm text-white/80 mb-4 leading-relaxed">
            Tell us about your facility and scope. We'll respond within one business day.
          </p>
          <a
            href="/quote"
            class="block w-full text-center bg-[var(--color-blue)] hover:bg-[var(--color-blue-light)] text-white font-semibold text-sm rounded-md px-4 py-3 transition"
          >
            Request a Quote
          </a>
          <a
            href="/contact"
            class="block w-full text-center mt-2 border border-white/30 hover:border-white/60 text-white/90 hover:text-white font-medium text-sm rounded-md px-4 py-3 transition"
          >
            Contact Us
          </a>
        </div>

        {/* Back link */}
        <a href="/projects" class="flex items-center gap-2 text-sm text-[var(--color-blue)] hover:text-[var(--color-navy)] font-medium transition group">
          <svg class="w-4 h-4 transition group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          All Projects
        </a>
      </aside>
    </div>
  </section>

  <CTASection
    heading="Ready to Upgrade Your Facility?"
    subhead="Surgiquip Solutions has 43 years of experience installing and servicing surgical equipment across Texas. Let's talk about your project."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Call (713) 681-6362"
    secondaryHref="tel:+17136816362"
  />
</BaseLayout>
