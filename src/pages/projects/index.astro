---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

// Fetch all projects from content collection
const allProjects = await getCollection('projects');
// Sort: featured first → dated entries descending → undated entries alphabetically by facility
const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  const ay = a.data.year ?? null;
  const by = b.data.year ?? null;
  // Both have years — descending
  if (ay !== null && by !== null) return by - ay;
  // Only a has a year — a comes first
  if (ay !== null) return -1;
  // Only b has a year — b comes first
  if (by !== null) return 1;
  // Neither has a year — stable alphabetical by facility
  return a.data.facility.localeCompare(b.data.facility);
});

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Case Studies & Installation Projects',
  description: 'OR installation projects and case studies from Surgiquip Solutions — hybrid OR builds, surgical suite upgrades, and equipment deployments across Texas healthcare facilities.',
  url: `${site.url}/projects`,
  provider: { '@type': 'LocalBusiness', name: site.brand, url: site.url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.url}/projects` },
  ],
};

const statusClasses = (status: string) =>
  status === 'Active' || status === 'Ongoing'
    ? 'bg-green-100 text-green-800'
    : 'bg-[var(--color-surface-alt)] text-[var(--color-text-muted)]';
---
<BaseLayout
  title="Projects & Case Studies | Surgiquip Solutions"
  description="OR installation projects from Surgiquip Solutions — hybrid OR builds, surgical suite upgrades, and equipment deployments across Texas healthcare."
  schema={[pageSchema, breadcrumbSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li class="text-white/90" aria-current="page">Projects</li>
        </ol>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Projects</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Case Studies & Installations
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Over {site.yearsInBusiness} years and 500+ facilities — a few examples of the work we're known for.
      </p>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Project Portfolio</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What We've Built and Serviced</h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Our project portfolio ranges from single-room surgical table replacements to complete hybrid OR integration builds. Detailed case studies with client data are shared under NDA — contact us and we'll provide references appropriate to your project scope.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <article class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition flex flex-col">
          <div class="flex items-start justify-between gap-2 mb-3 flex-wrap">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-surface-alt)] text-[var(--color-navy)]">
                {project.data.type}
              </span>
              {project.data.featured && (
                <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-blue)]/10 text-[var(--color-blue)]">
                  Featured
                </span>
              )}
            </div>
            <span class={`inline-block px-2 py-0.5 text-xs font-bold rounded ${statusClasses(project.data.status)}`}>
              {project.data.status}
            </span>
          </div>

          <h3 class="font-display text-lg font-bold text-[var(--color-navy)] mb-2 leading-snug">
            {project.data.title}
          </h3>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4 flex-1">
            {project.data.scope}
          </p>

          <div class="flex items-center justify-between text-xs text-[var(--color-text-muted)] border-t border-[var(--color-border)] pt-4 mt-auto">
            <div>
              <span class="block">{project.data.facility}</span>
              <span class="block">{project.data.location}{project.data.year != null ? ` · ${project.data.year}` : ''}</span>
            </div>
            <span class="font-semibold text-[var(--color-navy)] text-sm">{project.data.value}</span>
          </div>

          <a
            href={`/projects/${project.id}`}
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-blue)] hover:text-[var(--color-navy)] transition group"
            aria-label={`Read full case study: ${project.data.title}`}
          >
            Read Case Study
            <svg class="w-4 h-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-10 p-6 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] max-w-2xl">
      <div class="font-bold text-[var(--color-navy)] mb-2">Detailed Case Studies Available On Request</div>
      <p class="text-sm text-[var(--color-text-muted)]">
        We're happy to provide specific project references, photos, and client contacts for projects that match your scope. Contact us with details about your facility and project type.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 mt-4 btn-primary text-sm">Request References</a>
    </div>
  </section>

  <CTASection
    heading="Planning a Similar Project?"
    subhead="Tell us about your facility and scope. We'll walk you through how we'd approach it — no obligation."
    primaryLabel="Discuss Your Project"
    primaryHref="/quote"
  />
</BaseLayout>
