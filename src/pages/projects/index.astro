---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';
---
<BaseLayout
  title="Projects & Case Studies | Surgiquip Solutions"
  description="OR installation projects and case studies from Surgiquip Solutions — hybrid OR builds, surgical suite upgrades, and equipment deployments across Texas healthcare facilities."
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Projects</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Case Studies & Installations
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Over {site.yearsInBusiness} years and 500+ facilities — a few examples of the work we're known for.
      </p>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Featured Projects</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What We've Built and Serviced</h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Our project portfolio ranges from single-room surgical table replacements to complete hybrid OR integration builds. Detailed case studies with client data are shared under NDA — contact us and we'll provide references appropriate to your project scope.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {[
        {
          type: 'Hybrid OR Installation',
          scope: 'Full hybrid OR build — Skytron tables, lights, booms, 4K AV integration.',
          facility: 'Houston-area hospital system',
          value: '$1.2M+',
          status: 'Completed',
        },
        {
          type: 'Multi-Suite Upgrade',
          scope: '4-OR surgical table fleet replacement + light systems + PM contract.',
          facility: 'Southeast Texas surgery center',
          value: '$400K',
          status: 'Completed',
        },
        {
          type: 'Emergency Service',
          scope: 'Next-day table repair + commissioning to restore OR to service.',
          facility: 'Texas specialty clinic',
          value: 'Service call',
          status: 'Completed',
        },
        {
          type: 'PM Program',
          scope: 'Annual PM contract covering 8 surgical suites across 2 campuses.',
          facility: 'Regional health system',
          value: 'Ongoing',
          status: 'Active',
        },
        {
          type: 'Boom System Install',
          scope: 'Skytron equipment boom installation + gas outlet commissioning.',
          facility: 'Houston ambulatory surgery center',
          value: '$180K',
          status: 'Completed',
        },
        {
          type: 'Equipment Fleet',
          scope: 'Skytron surgical light system replacement across 6 ORs.',
          facility: 'Texas medical center facility',
          value: '$320K',
          status: 'Completed',
        },
      ].map((project) => (
        <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 hover:shadow-md transition">
          <div class="flex items-start justify-between gap-2 mb-3">
            <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-surface-alt)] text-[var(--color-navy)]">{project.type}</span>
            <span class={`inline-block px-2 py-0.5 text-xs font-bold rounded ${project.status === 'Active' ? 'bg-green-100 text-green-800' : 'bg-[var(--color-surface-alt)] text-[var(--color-text-muted)]'}`}>{project.status}</span>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">{project.scope}</p>
          <div class="flex items-center justify-between text-xs text-[var(--color-text-muted)] border-t border-[var(--color-border)] pt-3 mt-3">
            <span>{project.facility}</span>
            <span class="font-semibold text-[var(--color-navy)]">{project.value}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 p-6 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] max-w-2xl">
      <div class="font-bold text-[var(--color-navy)] mb-2">Detailed Case Studies Available On Request</div>
      <p class="text-sm text-[var(--color-text-muted)]">
        We're happy to provide specific project references, photos, and client contacts for projects that match your scope. Contact us with details about your facility and project type.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 mt-4 btn-primary text-sm">Request References</a>
    </div>
  </section>

  <CTASection
    heading="Planning a Similar Project?"
    subhead="Tell us about your facility and scope. We'll walk you through how we'd approach it — no obligation."
    primaryLabel="Discuss Your Project"
    primaryHref="/quote"
  />
</BaseLayout>
