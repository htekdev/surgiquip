---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

// Fetch all projects from content collection
const allProjects = await getCollection('projects');
// Sort: featured first, then by year descending (handle optional year gracefully)
const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});

// Build the unique project types for filter tabs (preserving insertion order after sort)
const uniqueTypes: string[] = [];
for (const p of projects) {
  if (!uniqueTypes.includes(p.data.type)) uniqueTypes.push(p.data.type);
}
// Count per type for badge labels
const countByType = Object.fromEntries(
  uniqueTypes.map((t) => [t, projects.filter((p) => p.data.type === t).length])
);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Case Studies & Installation Projects',
  description: 'OR installation projects and case studies from Surgiquip Solutions — hybrid OR builds, surgical suite upgrades, and equipment deployments across Texas healthcare facilities.',
  url: `${site.url}/projects`,
  provider: { '@type': 'LocalBusiness', name: site.brand, url: site.url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: `${site.url}/projects` },
  ],
};

const statusClasses = (status: string) =>
  status === 'Active' || status === 'Ongoing'
    ? 'bg-green-100 text-green-800'
    : 'bg-[var(--color-surface-alt)] text-[var(--color-text-muted)]';
---
<BaseLayout
  title="Projects & Case Studies | Surgiquip Solutions"
  description="OR installation projects from Surgiquip Solutions — hybrid OR builds, surgical suite upgrades, and equipment deployments across Texas healthcare."
  schema={[pageSchema, breadcrumbSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li class="text-white/90" aria-current="page">Projects</li>
        </ol>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Projects</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Case Studies & Installations
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Over {site.yearsInBusiness} years and 500+ facilities — a few examples of the work we're known for.
      </p>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Featured Projects</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What We've Built and Serviced</h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Our project portfolio ranges from single-room surgical table replacements to complete hybrid OR integration builds. Detailed case studies with client data are shared under NDA — contact us and we'll provide references appropriate to your project scope.
      </p>
    </div>

    {/* --- Filter tabs (G27) — client-side, no page reload --- */}
    {uniqueTypes.length > 1 && (
      <div id="project-filters" class="flex flex-wrap gap-2 mb-8" role="tablist" aria-label="Filter projects by type">
        <button
          type="button"
          role="tab"
          data-filter="all"
          aria-selected="true"
          class="filter-tab px-4 py-2 text-sm font-semibold rounded-full border border-[var(--color-border)] bg-[var(--color-navy)] text-white transition"
        >
          All
          <span class="ml-1.5 inline-flex items-center justify-center w-5 h-5 text-xs rounded-full bg-white/20">{projects.length}</span>
        </button>
        {uniqueTypes.map((type) => (
          <button
            type="button"
            role="tab"
            data-filter={type}
            aria-selected="false"
            class="filter-tab px-4 py-2 text-sm font-semibold rounded-full border border-[var(--color-border)] bg-white text-[var(--color-text)] hover:border-[var(--color-navy)] hover:text-[var(--color-navy)] transition"
          >
            {type}
            <span class="ml-1.5 inline-flex items-center justify-center w-5 h-5 text-xs rounded-full bg-[var(--color-surface-alt)]">{countByType[type]}</span>
          </button>
        ))}
      </div>
    )}

    {/* --- Project grid — data-type drives JS filter --- */}
    <div id="projects-grid" class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <article
          data-type={project.data.type}
          class="project-card bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition flex flex-col"
        >
          <div class="flex items-start justify-between gap-2 mb-3 flex-wrap">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-surface-alt)] text-[var(--color-navy)]">
                {project.data.type}
              </span>
              {project.data.featured && (
                <span class="inline-block px-2 py-0.5 text-xs font-bold rounded bg-[var(--color-blue)]/10 text-[var(--color-blue)]">
                  Featured
                </span>
              )}
            </div>
            <span class={`inline-block px-2 py-0.5 text-xs font-bold rounded ${statusClasses(project.data.status)}`}>
              {project.data.status}
            </span>
          </div>

          <h3 class="font-display text-lg font-bold text-[var(--color-navy)] mb-2 leading-snug">
            {project.data.title}
          </h3>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4 flex-1">
            {project.data.scope}
          </p>

          <div class="flex items-center justify-between text-xs text-[var(--color-text-muted)] border-t border-[var(--color-border)] pt-4 mt-auto">
            <div>
              <span class="block">{project.data.facility}</span>
              <span class="block">
                {project.data.location}{project.data.year != null ? ` · ${project.data.year}` : ''}
              </span>
            </div>
            <span class="font-semibold text-[var(--color-navy)] text-sm">{project.data.value}</span>
          </div>

          <a
            href={`/projects/${project.id}`}
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-blue)] hover:text-[var(--color-navy)] transition group"
            aria-label={`Read full case study: ${project.data.title}`}
          >
            Read Case Study
            <svg class="w-4 h-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </article>
      ))}
    </div>

    {/* No-results message (hidden until JS sets it) */}
    <p id="no-results" class="hidden text-center text-[var(--color-text-muted)] py-12 text-sm">
      No projects found for this category. <a href="/contact" class="text-[var(--color-blue)] underline hover:opacity-80">Contact us</a> to discuss your project type.
    </p>

    <div class="mt-10 p-6 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] max-w-2xl">
      <div class="font-bold text-[var(--color-navy)] mb-2">Detailed Case Studies Available On Request</div>
      <p class="text-sm text-[var(--color-text-muted)]">
        We're happy to provide specific project references, photos, and client contacts for projects that match your scope. Contact us with details about your facility and project type.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 mt-4 btn-primary text-sm">Request References</a>
    </div>
  </section>

  <CTASection
    heading="Planning a Similar Project?"
    subhead="Tell us about your facility and scope. We'll walk you through how we'd approach it — no obligation."
    primaryLabel="Discuss Your Project"
    primaryHref="/quote"
  />

  <script>
    // Projects filter — client-side tab switching.
    // Works with any number of types; renders gracefully with JS disabled (shows all).
    (function () {
      const tabs = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
      const cards = document.querySelectorAll<HTMLElement>('[data-type]');
      const noResults = document.getElementById('no-results');

      if (!tabs.length) return; // only 1 type — no tabs rendered

      function applyFilter(filter: string) {
        let visible = 0;

        cards.forEach((card) => {
          const match = filter === 'all' || card.dataset.type === filter;
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        if (noResults) noResults.classList.toggle('hidden', visible > 0);

        tabs.forEach((tab) => {
          const active = tab.dataset.filter === filter;
          tab.setAttribute('aria-selected', active ? 'true' : 'false');
          if (active) {
            tab.classList.add('bg-[var(--color-navy)]', 'text-white', 'border-[var(--color-navy)]');
            tab.classList.remove('bg-white', 'text-[var(--color-text)]');
          } else {
            tab.classList.remove('bg-[var(--color-navy)]', 'text-white', 'border-[var(--color-navy)]');
            tab.classList.add('bg-white', 'text-[var(--color-text)]');
          }
        });
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          applyFilter(tab.dataset.filter ?? 'all');
        });
      });
    })();
  </script>
</BaseLayout>
