---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer serving Victoria, TX and the Golden Crescent — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers in Victoria, Calhoun, Jackson, and DeWitt counties.',
  url: `${site.url}/service-areas/victoria-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 28.8053,
    longitude: -97.0036,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Victoria', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Port Lavaca', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Edna', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Cuero', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Victoria County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Calhoun County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Jackson County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'DeWitt County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Goliad County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Refugio County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Victoria, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Victoria, TX', item: `${site.url}/service-areas/victoria-tx` },
  ],
};

const services = [
  {
    href: '/services/equipment-sales',
    title: 'Surgical Equipment Sales',
    blurb:
      'Authorized Skytron dealer for Victoria and the Golden Crescent. Surgical tables, OR lighting systems, and equipment booms for DeTar Healthcare, Citizens Medical Center, and regional surgery centers.',
  },
  {
    href: '/services/or-installation',
    title: 'OR Installation & Integration',
    blurb:
      'Turnkey OR installations across the Golden Crescent — from coordination with your GC and architect through commissioning, staff training, and go-live support.',
  },
  {
    href: '/services/service-and-repair',
    title: 'Service & Repair',
    blurb:
      'Factory-trained technicians serving Victoria, Port Lavaca, Edna, Cuero, and surrounding counties. Emergency and scheduled service for Skytron and other major OR equipment brands.',
  },
  {
    href: '/services/preventive-maintenance',
    title: 'Preventive Maintenance',
    blurb:
      'Structured PM programs for surgical tables, overhead lights, and ceiling booms — with documentation formatted for Joint Commission survey readiness.',
  },
];

const victoriaStats = [
  { value: '43 Years', label: 'Texas OR expertise', sub: 'Since 1983' },
  { value: '6 Counties', label: 'Golden Crescent territory', sub: 'Victoria · Calhoun · Jackson · DeWitt · Goliad · Refugio' },
  { value: '24hr', label: 'Emergency response', sub: 'For critical equipment' },
  { value: 'Factory', label: 'Certified technicians', sub: 'Skytron authorized' },
];

const markets = [
  {
    city: 'Victoria',
    county: 'Victoria County',
    desc: 'Golden Crescent anchor market. Serving DeTar Healthcare System (DeTar Hospital Navarro and DeTar Hospital North) and Citizens Medical Center — Victoria\'s two major health systems managing OR and surgical suite equipment needs.',
  },
  {
    city: 'Port Lavaca / Calhoun County',
    county: 'Calhoun County',
    desc: 'Calhoun County hospital and outpatient surgical facilities on the Texas coast — covered for planned service visits and capital equipment needs as part of the broader Victoria territory.',
  },
  {
    city: 'Edna / Jackson County',
    county: 'Jackson County',
    desc: 'Jackson County regional healthcare facilities serving the communities between Victoria and the Houston corridor — emergency response and scheduled PM within our SE Texas service range.',
  },
  {
    city: 'Cuero / DeWitt County',
    county: 'DeWitt County',
    desc: 'DeWitt County medical facilities and outpatient surgery centers in the Golden Crescent interior — accessible for service calls, equipment consultations, and OR planning support.',
  },
];
---

<BaseLayout
  title="Surgical Equipment Victoria, TX | Surgiquip"
  description="Authorized Skytron dealer serving Victoria TX and the Golden Crescent. OR equipment sales, installation, service, and preventive maintenance."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/victoria-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Victoria, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Service Area</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment Sales &amp; Service in Victoria, TX
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions serves hospitals and surgery centers across the Victoria Golden Crescent — delivering factory-authorized Skytron equipment, professional OR installations, and ongoing service from our Houston base.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a
          href={`tel:${site.phoneE164}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[var(--color-navy-dark)] text-white">
    <div class="container-x py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
        {victoriaStats.map((s) => (
          <div class="px-6 py-4 text-center">
            <div class="font-display text-2xl font-bold text-white">{s.value}</div>
            <div class="text-xs text-white/70 mt-1">{s.label}</div>
            <div class="text-xs text-white/50 mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Markets grid -->
  <section class="container-x py-16">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Golden Crescent Coverage</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Communities We Serve</h2>
      <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
        From Victoria's major hospital systems to regional facilities across the Golden Crescent — Surgiquip serves the full mid-coast Texas market.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
      {markets.map((m) => (
        <div class="bg-white border border-[var(--color-border)] rounded-xl p-7">
          <h3 class="font-display text-xl font-bold text-[var(--color-navy)]">{m.city}</h3>
          <div class="text-xs font-semibold text-[var(--color-blue)] mt-1 mb-3">{m.county}</div>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Do</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Services for Victoria Facilities</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          Surgiquip delivers the full service spectrum — from initial equipment selection through installation, ongoing maintenance, and emergency repair.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        {services.map((s) => (
          <a href={s.href} class="group block bg-white border border-[var(--color-border)] rounded-xl p-7 hover:border-[var(--color-blue)] hover:shadow-md transition">
            <h3 class="font-display text-xl font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition">{s.title}</h3>
            <p class="mt-3 text-[var(--color-text-muted)] text-sm leading-relaxed">{s.blurb}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)]">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Surgiquip -->
  <section class="container-x py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] mb-6">
        The Authorized Dealer Difference in the Golden Crescent
      </h2>
      <div class="prose prose-slate max-w-none text-[var(--color-text-muted)] leading-relaxed space-y-4">
        <p>
          The Victoria healthcare market anchors the Golden Crescent region — with DeTar Healthcare System operating two hospital campuses and Citizens Medical Center serving as the region's county-owned facility, capital equipment demand here reflects a mature, stable market with ongoing replacement and upgrade cycles.
        </p>
        <p>
          As the <strong class="text-[var(--color-navy)]">authorized Skytron dealer for Southeast Texas</strong>, Surgiquip brings factory-certified technicians and direct OEM parts access to Victoria facilities. That distinction matters when a surgical table needs service before a full morning OR schedule — local authorized service means next-day response, not a parts order from a national 800-number.
        </p>
        <p>
          Victoria sits approximately 130 miles southwest of Houston on US-59 — well within our service territory and close enough for priority emergency dispatch when the situation calls for it. For planned PM programs and capital equipment projects, Surgiquip coordinates directly with facilities managers, GCs, and clinical staff — the same service model we've used across Southeast Texas since 1983.
        </p>
      </div>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          ['BBB A+', 'Accredited Business', 'Verified credibility since 1983'],
          ['Skytron Auth.', 'Authorized Dealer', 'Factory training & OEM parts'],
          ['500+ Facilities', 'Southeast Texas', 'Served across our territory'],
        ].map(([val, label, sub]) => (
          <div class="p-5 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] text-center">
            <div class="font-display text-xl font-bold text-[var(--color-navy)]">{val}</div>
            <div class="text-xs font-semibold text-[var(--color-blue)] mt-1">{label}</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources / Cross-links -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="max-w-3xl mx-auto">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Resources</div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-6">Useful Reading for Golden Crescent Facilities</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            {
              href: '/blog/or-table-selection-guide-texas-hospitals',
              label: 'OR Table Selection Guide',
              desc: 'How to evaluate surgical tables for Texas hospitals — table types, imaging compatibility, weight capacity, and Skytron options.',
            },
            {
              href: '/blog/preventive-maintenance-or-equipment-texas',
              label: 'Preventive Maintenance Guide',
              desc: 'PM checklists, intervals, and ROI for OR tables, surgical lights, and equipment booms.',
            },
            {
              href: '/services/or-installation',
              label: 'OR Installation & Integration',
              desc: 'Turnkey OR build-outs from project coordination through go-live support.',
            },
            {
              href: '/services/equipment-sales',
              label: 'Surgical Equipment Sales',
              desc: 'Authorized Skytron sales for surgical tables, OR lights, and ceiling booms.',
            },
          ].map((r) => (
            <a href={r.href} class="group block bg-white border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-blue)] hover:shadow-sm transition">
              <div class="font-semibold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition text-sm">{r.label}</div>
              <div class="text-xs text-[var(--color-text-muted)] mt-1 leading-relaxed">{r.desc}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Need Service in Victoria?"
    subhead="Tell us about your facility and equipment needs — we'll confirm coverage and respond within one business day."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Contact Our Team"
    secondaryHref="/contact"
  />
</BaseLayout>
