---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer serving Corpus Christi, TX and the Coastal Bend — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers in Nueces, San Patricio, Aransas, and Kleberg counties.',
  url: `${site.url}/service-areas/corpus-christi-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 27.8006,
    longitude: -97.3964,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Corpus Christi', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Portland', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Rockport', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Kingsville', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Nueces County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'San Patricio County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Aransas County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Kleberg County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Jim Wells County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Corpus Christi, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin, site.social.youtube],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Corpus Christi, TX', item: `${site.url}/service-areas/corpus-christi-tx` },
  ],
};

const services = [
  {
    href: '/services/equipment-sales',
    title: 'Surgical Equipment Sales',
    blurb:
      'Authorized Skytron dealer for Corpus Christi and the Coastal Bend. Surgical tables, OR lighting systems, and equipment booms for CHRISTUS Spohn, Driscoll Health, and regional ASCs.',
  },
  {
    href: '/services/or-installation',
    title: 'OR Installation & Integration',
    blurb:
      'Turnkey OR installations across South Texas — from coordination with your GC and architect through commissioning, staff training, and go-live support.',
  },
  {
    href: '/services/service-and-repair',
    title: 'Service & Repair',
    blurb:
      'Factory-trained technicians serving Corpus Christi, Portland, Rockport, and surrounding Coastal Bend counties. Emergency and scheduled service for Skytron and other major OR brands.',
  },
  {
    href: '/services/preventive-maintenance',
    title: 'Preventive Maintenance',
    blurb:
      'Structured PM programs for surgical tables, overhead lights, and ceiling booms — with documentation formatted for Joint Commission and DNV GL survey readiness.',
  },
];

const ccStats = [
  { value: '43 Years', label: 'Texas OR expertise', sub: 'Since 1983' },
  { value: '5 Counties', label: 'Coastal Bend territory', sub: 'Nueces · San Patricio · Aransas · Kleberg · Jim Wells' },
  { value: '24hr', label: 'Emergency response', sub: 'For critical equipment' },
  { value: 'Factory', label: 'Certified technicians', sub: 'Skytron authorized' },
];

const markets = [
  {
    city: 'Corpus Christi',
    county: 'Nueces County',
    desc: 'Coastal Bend anchor market. Serving CHRISTUS Spohn Health System (Shoreline, Memorial, South campuses), Corpus Christi Medical Center, and Bay Area Hospital.',
  },
  {
    city: 'Portland / Aransas Pass',
    county: 'San Patricio & Aransas Counties',
    desc: 'Serving Bay Area facilities and regional clinics across San Patricio County — immediate service range from Corpus Christi.',
  },
  {
    city: 'Rockport / Aransas County',
    county: 'Aransas County',
    desc: 'Aransas County hospitals and outpatient surgical facilities on the Texas Coastal Bend — covered for planned service visits and equipment needs.',
  },
  {
    city: 'Kingsville / Alice',
    county: 'Kleberg & Jim Wells Counties',
    desc: 'Driscoll Health Kleberg and South Texas regional health facilities — serving the communities south of Corpus Christi toward the Rio Grande Valley approach.',
  },
];
---

<BaseLayout
  title="Surgical Equipment Corpus Christi | Surgiquip"
  description="Authorized Skytron dealer serving Corpus Christi TX and the Coastal Bend. OR equipment sales, installation, service, and preventive maintenance."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/corpus-christi-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Corpus Christi, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Service Area</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment Sales &amp; Service in Corpus Christi, TX
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions serves hospitals and surgery centers across the Corpus Christi Coastal Bend — delivering factory-authorized Skytron equipment, professional OR installations, and ongoing service from our Houston base.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a
          href={`tel:${site.phoneE164}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[var(--color-navy-dark)] text-white">
    <div class="container-x py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
        {ccStats.map((s) => (
          <div class="px-6 py-4 text-center">
            <div class="font-display text-2xl font-bold text-white">{s.value}</div>
            <div class="text-xs text-white/70 mt-1">{s.label}</div>
            <div class="text-xs text-white/50 mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Markets grid -->
  <section class="container-x py-16">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Coastal Bend Coverage</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Communities We Serve</h2>
      <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
        From Corpus Christi's major hospital campuses to regional facilities across the Coastal Bend — Surgiquip serves the full South Texas market.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
      {markets.map((m) => (
        <div class="bg-white border border-[var(--color-border)] rounded-xl p-7">
          <h3 class="font-display text-xl font-bold text-[var(--color-navy)]">{m.city}</h3>
          <div class="text-xs font-semibold text-[var(--color-blue)] mt-1 mb-3">{m.county}</div>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Do</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Services for Corpus Christi Facilities</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          Surgiquip delivers the full service spectrum — from initial equipment selection through installation, ongoing maintenance, and emergency repair.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        {services.map((s) => (
          <a href={s.href} class="group block bg-white border border-[var(--color-border)] rounded-xl p-7 hover:border-[var(--color-blue)] hover:shadow-md transition">
            <h3 class="font-display text-xl font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition">{s.title}</h3>
            <p class="mt-3 text-[var(--color-text-muted)] text-sm leading-relaxed">{s.blurb}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)]">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Surgiquip -->
  <section class="container-x py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] mb-6">
        The Authorized Dealer Difference in South Texas
      </h2>
      <div class="prose prose-slate max-w-none text-[var(--color-text-muted)] leading-relaxed space-y-4">
        <p>
          The Corpus Christi healthcare market is growing — CHRISTUS Spohn's multi-campus system, Driscoll Health's pediatric specialization, and the region's ambulatory surgery center expansion all represent real capital equipment demand. Surgiquip Solutions has served the broader Southeast Texas market since 1983, and the Coastal Bend is a natural extension of our territory.
        </p>
        <p>
          As the <strong class="text-[var(--color-navy)]">authorized Skytron dealer for Southeast Texas</strong>, Surgiquip brings factory-certified technicians and direct OEM parts access to Corpus Christi facilities. That distinction matters when a surgical table needs service on a Wednesday morning before a full OR schedule.
        </p>
        <p>
          Our service model is designed for the reality of healthcare operations — not just sales visits followed by 800-number support. When Corpus Christi facilities call, they reach a team that knows their equipment and their region.
        </p>
      </div>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          ['BBB A+', 'Accredited Business', 'Verified credibility since 1983'],
          ['Skytron Auth.', 'Authorized Dealer', 'Factory training & OEM parts'],
          ['500+ Facilities', 'Southeast Texas', 'Served across our territory'],
        ].map(([val, label, sub]) => (
          <div class="p-5 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] text-center">
            <div class="font-display text-xl font-bold text-[var(--color-navy)]">{val}</div>
            <div class="text-xs font-semibold text-[var(--color-blue)] mt-1">{label}</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources / Cross-links -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="max-w-3xl mx-auto">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Resources</div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)] mb-6">Useful Reading for Coastal Bend Facilities</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            {
              href: '/blog/surgical-lighting-guide-texas-hospitals',
              label: 'Surgical Lighting Guide',
              desc: 'Specs, configuration options, and upgrade ROI for Texas OR lighting systems.',
            },
            {
              href: '/blog/or-installation-planning-guide-texas',
              label: 'OR Installation Planning Guide',
              desc: 'Phase-by-phase planning guide for Texas hospital OR installations.',
            },
            {
              href: '/services/preventive-maintenance',
              label: 'Preventive Maintenance Programs',
              desc: 'Structured PM for surgical tables, lights, and booms — survey-ready documentation.',
            },
            {
              href: '/services/or-installation',
              label: 'OR Installation & Integration',
              desc: 'Turnkey OR build-outs from project coordination through go-live support.',
            },
          ].map((r) => (
            <a href={r.href} class="group block bg-white border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-blue)] hover:shadow-sm transition">
              <div class="font-semibold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition text-sm">{r.label}</div>
              <div class="text-xs text-[var(--color-text-muted)] mt-1 leading-relaxed">{r.desc}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Need Service in Corpus Christi?"
    subhead="Tell us about your facility and equipment needs — we'll confirm coverage and respond within one business day."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Contact Our Team"
    secondaryHref="/contact"
  />
</BaseLayout>
