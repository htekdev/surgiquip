---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'El Paso, TX', item: `${site.url}/service-areas/el-paso-tx` },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  description:
    'Authorized Skytron dealer serving El Paso and the Borderland region — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers in El Paso County and surrounding areas since 1983.',
  url: site.url,
  telephone: site.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 31.7619,
    longitude: -106.485,
  },
  areaServed: [
    { '@type': 'City', name: 'El Paso', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Socorro', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Horizon City', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Anthony', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'El Paso County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Surgical Equipment Services — El Paso TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Equipment Sales', areaServed: 'El Paso, TX' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Operating Room Installation', areaServed: 'El Paso, TX' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Service & Repair', areaServed: 'El Paso, TX' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance', areaServed: 'El Paso, TX' } },
    ],
  },
};
---

<BaseLayout
  title="El Paso TX Surgical Equipment — OR Sales, Installation & Service | Surgiquip Solutions"
  description="Surgiquip Solutions serves El Paso and the Borderland region — authorized Skytron dealer for OR equipment sales, installation, service, and preventive maintenance. Hospitals of Providence, UMC, Del Sol, and El Paso Children's. Call (713) 681-6362."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/el-paso-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">El Paso, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">West Texas · Borderland</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        El Paso, TX — Surgical Equipment Sales, Installation & Service
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions is the authorized Skytron dealer for El Paso and the Borderland region — serving The Hospitals of Providence, UMC Health System, Del Sol Medical Center, El Paso Children's Hospital, and the rapidly expanding ASC corridor along the I-10 corridor.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/>
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Market overview stats -->
  <section class="bg-[var(--color-surface-alt)] py-10 border-b border-[var(--color-border)]">
    <div class="container-x">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center max-w-3xl mx-auto">
        {[
          ['900K+', 'El Paso Metro Population'],
          ['10+', 'Major Hospitals & Health Systems'],
          ['43 Years', 'Surgiquip in Texas'],
          ['Skytron', 'Authorized Dealer'],
        ].map(([val, label]) => (
          <div>
            <div class="font-display text-2xl font-bold text-[var(--color-navy)]">{val}</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Healthcare market overview -->
  <section class="container-x py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">El Paso Healthcare Market</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] mb-6">
        The Borderland's Growing Healthcare Corridor
      </h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
        El Paso is one of the most dynamic healthcare markets in Texas. With a binational metro population exceeding 2.5 million (including Ciudad Juárez), El Paso County hospitals serve a large, underserved population with a high proportion of Medicaid and federal programs — driving significant capital investment in OR infrastructure over the past decade.
      </p>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-8">
        Surgiquip Solutions supports OR teams, biomedical engineers, and facility directors across the El Paso market with authorized Skytron equipment, factory-trained technicians, and the same level of service that Houston-area health systems have relied on since 1983.
      </p>

      <!-- Hospital system grid -->
      <div class="grid gap-4 md:grid-cols-2">
        {[
          {
            name: 'The Hospitals of Providence (TENET)',
            locations: "Sierra Campus, Transmountain Campus, East Campus, Memorial Campus, Children's Hospital",
            desc: "TENET-affiliated regional health system covering multiple El Paso campuses, including the only children's hospital in the Borderland.",
          },
          {
            name: 'University Medical Center of El Paso',
            locations: 'El Paso County Hospital District',
            desc: "Level 1 Trauma Center and teaching hospital affiliated with Texas Tech University Health Sciences Center El Paso — the region's safety-net hospital.",
          },
          {
            name: 'Del Sol Medical Center',
            locations: 'East El Paso',
            desc: 'HCA-affiliated acute care facility with a fully equipped surgical suite serving east El Paso and Fort Bliss / Biggs Army Airfield.',
          },
          {
            name: 'Las Palmas Medical Center',
            locations: 'West El Paso / Scenic Drive Corridor',
            desc: 'HCA-affiliated facility serving the west-side corridor with a strong surgical census and cardiovascular program.',
          },
        ].map((h) => (
          <div class="p-6 bg-white border border-[var(--color-border)] rounded-xl">
            <h3 class="font-display text-lg font-bold text-[var(--color-navy)] mb-1">{h.name}</h3>
            <div class="text-xs font-semibold text-[var(--color-blue)] mb-2">{h.locations}</div>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-10">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Do in El Paso</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">OR Equipment Services</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 max-w-5xl mx-auto">
        {[
          {
            title: 'Equipment Sales',
            icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
            desc: 'Authorized Skytron OR tables, surgical lights, ceiling booms, and accessories. Factory-direct pricing, full warranty, and local support.',
          },
          {
            title: 'OR Installation',
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9',
            desc: 'Full OR suite installation — electrical coordination, structural anchoring, medical gas integration, final commissioning, and staff training.',
          },
          {
            title: 'Service & Repair',
            icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
            desc: 'Factory-authorized repair and emergency response for all Skytron equipment — OR tables, surgical lights, booms, and power systems.',
          },
          {
            title: 'Preventive Maintenance',
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
            desc: 'Comprehensive PM programs compliant with TJC EC.02.04.01, AORN guidelines, and manufacturer specifications. Detailed documentation for regulatory compliance.',
          },
        ].map((s) => (
          <div class="p-6 bg-white rounded-xl border border-[var(--color-border)]">
            <div class="w-12 h-12 rounded-full bg-[var(--color-navy)]/10 flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-[var(--color-navy)] mb-2">{s.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Surgiquip in El Paso -->
  <section class="container-x py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] mb-6">
        Texas-Based. Factory-Authorized. Always Local.
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        {[
          {
            title: 'Authorized Skytron Dealer',
            desc: 'Factory-trained and authorized to sell, install, and service all Skytron product lines — OR tables, surgical lights, ceiling booms, and accessories — for Texas healthcare facilities.',
          },
          {
            title: '43 Years in Texas',
            desc: 'Founded in Houston in 1983, Surgiquip has built its reputation on reliable service, honest pricing, and long-term hospital relationships across the state.',
          },
          {
            title: 'BBB A+ Accredited',
            desc: 'Accredited by the Better Business Bureau with an A+ rating — the independent verification that our business practices meet the highest ethical standards.',
          },
          {
            title: 'Compliance-Ready Documentation',
            desc: 'Every PM visit produces documentation formatted for TJC, DNV GL, HFAP, and CMS surveys — so your biomedical and facilities team is always audit-ready.',
          },
          {
            title: 'Fast Response Times',
            desc: "Critical equipment failures can't wait. We prioritize emergency service calls for Skytron equipment and keep replacement parts in inventory to minimize OR downtime.",
          },
          {
            title: 'Statewide Network',
            desc: 'With clients from Houston to El Paso to Lubbock, Surgiquip understands the logistical realities of Texas healthcare — distances, shipping, and regional parts availability.',
          },
        ].map((w) => (
          <div class="p-5 bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)]">
            <h3 class="font-display text-base font-bold text-[var(--color-navy)] mb-2">{w.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources section -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Resources for El Paso Facility Teams</h2>
        <p class="mt-2 text-[var(--color-text-muted)] max-w-xl mx-auto">Technical guides, compliance references, and planning resources for OR managers and biomedical engineers.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-3 max-w-4xl mx-auto">
        <a href="/blog/or-suite-renovation-planning-guide-texas-hospitals" class="p-5 bg-white rounded-xl border border-[var(--color-border)] hover:border-[var(--color-blue)] transition group">
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">Planning Guide</div>
          <h3 class="font-display text-base font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition">OR Suite Renovation Planning Guide for Texas Hospitals</h3>
        </a>
        <a href="/blog/joint-commission-or-equipment-compliance-texas-hospitals" class="p-5 bg-white rounded-xl border border-[var(--color-border)] hover:border-[var(--color-blue)] transition group">
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">Compliance</div>
          <h3 class="font-display text-base font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition">Joint Commission OR Equipment Compliance: Texas Hospitals Guide</h3>
        </a>
        <a href="/blog/ambulatory-surgery-center-equipment-guide-texas" class="p-5 bg-white rounded-xl border border-[var(--color-border)] hover:border-[var(--color-blue)] transition group">
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-2">ASC Guide</div>
          <h3 class="font-display text-base font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition">ASC Equipment Guide: CMS CoP Compliance for Texas Surgery Centers</h3>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    heading="Have a Facility in El Paso?"
    subhead="Tell us what you need — OR equipment sales, installation, service, or preventive maintenance. We'll respond within one business day."
    primaryLabel="Contact Our Team"
    primaryHref="/contact"
    secondaryLabel="Request a Quote"
  />
</BaseLayout>
