---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer serving the Rio Grande Valley, TX — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers in Hidalgo, Cameron, Starr, and Willacy counties.',
  url: `${site.url}/service-areas/rio-grande-valley-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 26.2034,
    longitude: -98.2300,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'McAllen', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Harlingen', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Brownsville', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Edinburg', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Weslaco', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Mission', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Hidalgo County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Cameron County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Starr County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Willacy County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Rio Grande Valley, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin, site.social.youtube],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Rio Grande Valley, TX', item: `${site.url}/service-areas/rio-grande-valley-tx` },
  ],
};

const services = [
  {
    href: '/services/equipment-sales',
    title: 'Surgical Equipment Sales',
    blurb:
      'Authorized Skytron dealer for the Rio Grande Valley. Surgical tables, OR lighting systems, and ceiling-mounted boom systems for DHR Health, South Texas Health System, Valley Baptist, Knapp Medical Center, and regional surgery centers.',
  },
  {
    href: '/services/or-installation',
    title: 'OR Installation & Integration',
    blurb:
      'Turnkey OR installations across Hidalgo and Cameron counties — from coordination with your GC and architect through commissioning, staff training, and go-live support for new builds and renovation projects serving the RGV\'s rapidly growing healthcare market.',
  },
  {
    href: '/services/service-and-repair',
    title: 'Service & Repair',
    blurb:
      'Factory-trained technicians serving McAllen, Harlingen, Brownsville, Edinburg, and surrounding communities. Emergency and scheduled service for Skytron and other major OR equipment brands across the Rio Grande Valley.',
  },
  {
    href: '/services/preventive-maintenance',
    title: 'Preventive Maintenance',
    blurb:
      'Structured PM programs for surgical tables, overhead lights, and ceiling booms — with documentation formatted for Joint Commission and CMS survey readiness across RGV facilities.',
  },
];

const rgvStats = [
  { value: '43 Years', label: 'Texas OR expertise', sub: 'Since 1983' },
  { value: '4 Counties', label: 'RGV territory', sub: 'Hidalgo · Cameron · Starr · Willacy' },
  { value: '24hr', label: 'Emergency response', sub: 'For critical equipment' },
  { value: 'Factory', label: 'Certified technicians', sub: 'Skytron authorized' },
];

const markets = [
  {
    city: 'McAllen / Hidalgo County',
    county: 'Hidalgo County',
    desc: "The Rio Grande Valley's largest healthcare hub. Serving DHR Health (a major regional health system in Edinburg/McAllen), South Texas Health System (McAllen Medical Center, Edinburg Regional Medical Center, Mission Regional Medical Center, Edinburg Children's Hospital), Doctors Hospital at Renaissance, and the expanding outpatient surgical center market driven by the RGV's population growth.",
  },
  {
    city: 'Harlingen / Cameron County',
    county: 'Cameron County',
    desc: 'Valley Baptist Medical Center — Harlingen, a major tertiary-care facility serving the mid-Valley — plus Harlingen Medical Center and outpatient surgical centers serving a rapidly growing residential and commercial corridor on US-83 between McAllen and Brownsville.',
  },
  {
    city: 'Brownsville / South Cameron County',
    county: 'Cameron County South',
    desc: 'Valley Baptist Medical Center — Brownsville and the University of Texas Rio Grande Valley Health System facilities serving the southernmost Texas border market. Growing capital equipment investment driven by healthcare infrastructure expansion in Cameron County.',
  },
  {
    city: 'Weslaco · Mission · Starr County',
    county: 'Hidalgo · Starr Counties',
    desc: 'Knapp Medical Center (Weslaco), Mission Regional Medical Center, and critical access and rural health facilities in Starr County — covered for capital equipment consultation, OR installation coordination, and ongoing service and preventive maintenance.',
  },
];
---

<BaseLayout
  title="Rio Grande Valley, TX Surgical Equipment — Sales, Service & OR Installation | Surgiquip Solutions"
  description="Surgiquip Solutions serves hospitals and surgery centers in the Rio Grande Valley — authorized Skytron dealer for surgical tables, OR lighting, equipment booms, service, and preventive maintenance across Hidalgo, Cameron, Starr, and Willacy counties."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/rio-grande-valley-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Rio Grande Valley, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Rio Grande Valley</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment for the Rio Grande Valley
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions serves hospitals, surgery centers, and specialty clinics across the Rio Grande Valley —
        authorized Skytron dealer for OR tables, lighting systems, ceiling booms, and full-lifecycle service since 1983.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a
          href={`tel:${site.phoneE164}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[var(--color-navy-dark)] text-white">
    <div class="container-x py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 divide-y md:divide-y-0 md:divide-x divide-white/10">
        {rgvStats.map((s) => (
          <div class="text-center py-2 first:pt-0 last:pb-0 md:py-0">
            <div class="font-display text-2xl font-bold text-white">{s.value}</div>
            <div class="text-xs text-white/70 mt-1 leading-tight">{s.label}</div>
            <div class="text-xs text-white/50 mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Markets grid -->
  <section class="container-x py-16">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Coverage Area</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Rio Grande Valley Markets</h2>
      <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
        From Hidalgo County's major health systems to Cameron County's tertiary-care facilities and border community
        hospitals — Surgiquip provides authorized OR equipment service across the Valley.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
      {markets.map((m) => (
        <div class="bg-white border border-[var(--color-border)] rounded-xl p-7">
          <div class="flex items-start gap-3 mb-3">
            <div class="w-9 h-9 rounded-full bg-[var(--color-navy)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-[var(--color-navy)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="font-display text-lg font-bold text-[var(--color-navy)]">{m.city}</h3>
              <div class="text-xs text-[var(--color-text-muted)]">{m.county}</div>
            </div>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Do</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">OR Services for RGV Hospitals</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          Full-lifecycle OR equipment coverage — from initial purchase through installation, ongoing service, and
          planned preventive maintenance — for healthcare facilities across the Rio Grande Valley.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        {services.map((s) => (
          <a
            href={s.href}
            class="group block bg-white border border-[var(--color-border)] rounded-xl p-7 hover:border-[var(--color-blue)] hover:shadow-md transition"
          >
            <h3 class="font-display text-xl font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition mb-3">
              {s.title}
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{s.blurb}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)]">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Surgiquip trust block -->
  <section class="container-x py-16">
    <div class="text-center mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">
        The RGV's Healthcare Market Deserves an Authorized Partner
      </h2>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed max-w-2xl mx-auto">
        The Rio Grande Valley is one of Texas's fastest-growing healthcare markets — and one of its most underserved for
        capital OR equipment expertise. Surgiquip brings 43 years of Texas OR experience, factory authorization from Skytron,
        and a service commitment that extends well beyond the sale.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-3 max-w-4xl mx-auto">
      {[
        {
          title: 'Skytron Authorized Dealer',
          body: 'The only authorized Skytron dealer serving Southeast Texas and South Texas — giving RGV facilities access to genuine parts, factory-level service, and warranty coverage that third-party distributors cannot provide.',
        },
        {
          title: '24-Hour Emergency Response',
          body: 'OR equipment failures can\'t wait until Monday. Our factory-trained technicians are available for emergency service calls across the Rio Grande Valley — because a down surgical table or failed OR light is a patient care issue.',
        },
        {
          title: 'Survey-Ready Documentation',
          body: 'Our PM programs generate Joint Commission and CMS-formatted maintenance records — so when a surveyor asks for your PM documentation on that Skytron table, you can pull it immediately.',
        },
      ].map((item) => (
        <div class="bg-[var(--color-surface-alt)] border border-[var(--color-border)] rounded-xl p-7">
          <h3 class="font-display text-lg font-bold text-[var(--color-navy)] mb-3">{item.title}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Resources cross-links -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Resources for RGV Healthcare Facilities</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">Technical guides and planning resources for OR equipment decisions.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 max-w-3xl mx-auto">
        {[
          {
            href: '/blog/ceiling-boom-systems-guide-texas-hospitals',
            title: 'Ceiling Boom Systems: Buyer\'s Guide for Texas Hospitals',
            desc: 'Types, specifications, structural requirements, PM schedules, and vendor evaluation criteria.',
          },
          {
            href: '/blog/or-installation-planning-guide-texas',
            title: 'OR Installation Planning Guide for Texas Hospitals',
            desc: 'From concept to commissioning — what to expect from an OR installation project.',
          },
        ].map((r) => (
          <a href={r.href} class="group flex gap-4 bg-white border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-blue)] hover:shadow-md transition">
            <div class="flex-1">
              <div class="font-semibold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition text-sm leading-snug mb-1">{r.title}</div>
              <div class="text-xs text-[var(--color-text-muted)]">{r.desc}</div>
            </div>
            <svg class="w-5 h-5 text-[var(--color-blue)] flex-shrink-0 mt-0.5 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Have a Facility in the Rio Grande Valley?"
    subhead="Tell us about your equipment needs — we'll confirm coverage and respond within one business day."
    primaryLabel="Contact Our Team"
    primaryHref="/contact"
    secondaryLabel="Request a Quote"
  />
</BaseLayout>
