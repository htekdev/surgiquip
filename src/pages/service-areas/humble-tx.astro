---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  description:
    'Authorized Skytron dealer serving Humble, TX hospitals and surgery centers since 1983. OR equipment sales, hybrid OR integration, service and preventive maintenance in northeast Harris County.',
  url: `${site.url}/service-areas/humble-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 29.9988,
    longitude: -95.2621,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Humble', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Harris County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Humble, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Hybrid OR Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin, site.social.youtube],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Humble, TX', item: `${site.url}/service-areas/humble-tx` },
  ],
};
---
<BaseLayout
  title="Surgical Equipment — Humble, TX | Surgiquip Solutions"
  description="Surgiquip Solutions serves Humble, TX — authorized Skytron dealer for northeast Houston. OR equipment, hybrid OR integration with Philips imaging. Memorial Hermann Northeast reference site."
  schema={[localBusinessSchema, breadcrumbSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Humble, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Northeast Houston · Harris County</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Surgical Equipment Service — Humble, TX
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Authorized Skytron dealer serving northeast Houston and Humble-area healthcare facilities since 1983.
        Proven hybrid OR experience — including Philips imaging integration at Memorial Hermann Northeast.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="inline-flex items-center gap-2 bg-[var(--color-blue)] hover:bg-[var(--color-blue-light)] text-white font-semibold px-6 py-3 rounded-lg transition">
          Request Quote
        </a>
        <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 border border-white/30 hover:border-white text-white font-semibold px-6 py-3 rounded-lg transition">
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ── Reference Installation ─────────────────────────────────────────────── -->
  <section class="bg-[var(--color-surface-alt)] py-14 border-b border-[var(--color-border)]">
    <div class="container-x">
      <div class="max-w-4xl mx-auto">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Reference Installation</div>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-[var(--color-navy)] mb-4">
          Memorial Hermann Northeast
        </h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Surgiquip Solutions equipped Memorial Hermann Northeast with Center Mount Booms, Aurora LED surgical
          lights, 6701 Skytron surgical tables, and a hybrid OR integrated with Philips imaging systems.
          The Humble campus project involved multiple operating rooms and a full hybrid OR build — requiring
          precise coordination of ceiling-mount boom configurations around the Philips C-arm envelope.
          This installation is one of four confirmed Surgiquip hybrid OR projects in the Greater Houston area.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Markets Grid ───────────────────────────────────────────────────────── -->
  <section class="container-x py-16">
    <div class="text-center mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Northeast Houston Healthcare</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {[
        { name: 'Hospitals', desc: 'Full-service OR equipment programs for Humble and northeast Houston hospitals.' },
        { name: 'Hybrid OR', desc: 'Proven hybrid OR integration with Philips, Siemens, and GE imaging systems.' },
        { name: 'Surgery Centers', desc: 'Right-sized OR equipment packages for northeast Houston ambulatory surgery centers.' },
        { name: 'Service & PM', desc: 'Preventive maintenance and repair for existing Skytron and multi-brand equipment fleets.' },
      ].map((m) => (
        <div class="bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] p-6">
          <h3 class="font-bold text-[var(--color-navy)] mb-2">{m.name}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <CTASection
    heading="Serving Humble & Northeast Houston"
    subhead={`Contact Surgiquip Solutions at ${site.phone} — authorized Skytron dealer for Southeast Texas since 1983.`}
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Contact Us"
    secondaryHref="/contact"
  />
</BaseLayout>
