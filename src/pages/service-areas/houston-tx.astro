---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer serving Houston, TX hospitals, surgery centers, and healthcare facilities since 1983. OR equipment sales, installation, service, and preventive maintenance.',
  url: `${site.url}/service-areas/houston-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 29.682,
    longitude: -95.552,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Houston', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Harris County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Fort Bend County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Montgomery County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Brazoria County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Houston, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin, site.social.youtube],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Houston, TX', item: `${site.url}/service-areas/houston-tx` },
  ],
};

const facilities = [
  { name: 'Hospitals & Health Systems', desc: 'Full-service OR equipment programs for acute care hospitals — from capital planning through lifecycle maintenance.', icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>' },
  { name: 'Ambulatory Surgery Centers', desc: 'Right-sized OR equipment packages for ASCs — Skytron tables and lights, fast installation, minimal downtime.', icon: '<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 12h6M12 9v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>' },
  { name: 'Specialty Surgery Centers', desc: 'Orthopedic, spine, and cardiac specialty rooms with custom table and lighting configurations for procedural workflows.', icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>' },
  { name: 'Hybrid OR & Cath Labs', desc: 'Complex AV integration, boom configurations, and hybrid OR builds for cardiac and vascular programs.', icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>' },
];

const services = [
  {
    href: '/services/equipment-sales',
    title: 'Surgical Equipment Sales',
    blurb: 'Authorized dealer for Skytron, HSI, and Knight. Surgical tables, OR lights, equipment booms, and accessories — capital purchase or replacement programs.',
  },
  {
    href: '/services/or-installation',
    title: 'OR Installation & Integration',
    blurb: 'Turnkey installation from planning to go-live. We coordinate with your GC, architect, and biomedical team. Projects from $30K to $2M+.',
  },
  {
    href: '/services/service-and-repair',
    title: 'Service & Repair',
    blurb: 'Factory-trained technicians for same-day or next-day response across Greater Houston. Parts stocked locally for Skytron systems.',
  },
  {
    href: '/services/preventive-maintenance',
    title: 'Preventive Maintenance',
    blurb: 'Annual PM programs designed for Joint Commission compliance — documented service records, calibration logs, and OEM-specification maintenance.',
  },
];

const houstonStats = [
  { value: '43 Years', label: 'Houston-area service', sub: 'Since 1983' },
  { value: 'Harris + 4', label: 'Counties served', sub: 'Greater Houston area' },
  { value: '24hr', label: 'Service response', sub: 'For critical equipment' },
  { value: 'A+ BBB', label: 'Accredited', sub: 'Better Business Bureau' },
];
---

<BaseLayout
  title="Surgical Equipment Sales & Service — Houston, TX | Surgiquip Solutions"
  description="Surgiquip Solutions serves hospitals and surgery centers across Houston, TX. Authorized Skytron dealer — OR equipment sales, installation, repair, and preventive maintenance since 1983."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/houston-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Houston, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Service Area</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment Sales &amp; Service in Houston, TX
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions has served Greater Houston hospitals, surgery centers, and specialty clinics since 1983. Authorized Skytron dealer. Factory-trained technicians based in Houston.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/>
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[#061e42] text-white">
    <div class="container-x py-6">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {houstonStats.map((s) => (
          <div>
            <dt class="sr-only">{s.label}</dt>
            <dd class="font-display text-2xl md:text-3xl font-bold">{s.value}</dd>
            <p class="text-xs text-white/70 mt-1 leading-snug">{s.label}<br /><span class="text-white/50">{s.sub}</span></p>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Intro -->
  <section class="container-x py-16">
    <div class="max-w-3xl">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Serving Greater Houston</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
        Houston's OR Equipment Partner Since 1983
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        From Memorial Hermann and Houston Methodist to community hospitals and freestanding ASCs in Harris, Fort Bend, Montgomery, and Brazoria counties — Surgiquip Solutions has been the surgical equipment partner of choice for Houston-area healthcare facilities for over four decades.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        As the authorized Skytron dealer for Southeast Texas, we offer the full Skytron line — surgical tables, surgical lighting, equipment booms, and accessories — alongside HSI and Knight products. Our factory-trained technicians are Houston-based, which means faster response times and local accountability.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Whether you're equipping a new OR suite, replacing aging capital equipment, or establishing a preventive maintenance program, Surgiquip brings four decades of Houston healthcare relationships and manufacturer-level expertise to your project.
      </p>
    </div>
  </section>

  <!-- Service Territory Map -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Service Territory</div>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
            Greater Houston &amp; Southeast Texas
          </h2>
          <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
            Surgiquip Solutions maintains an authorized Skytron dealer territory covering Greater Houston and Southeast Texas — one of the most healthcare-dense markets in the United States. Our Houston-based technicians provide rapid response across the entire service territory.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              ['Harris County', 'Houston and all surrounding districts'],
              ['Fort Bend County', 'Sugar Land, Missouri City, Richmond'],
              ['Montgomery County', 'The Woodlands, Conroe, Kingwood'],
              ['Brazoria County', 'Pearland, Lake Jackson, Alvin'],
              ['Southeast Texas', 'Jefferson, Orange, Hardin, Jasper counties'],
            ].map(([county, cities]) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 shrink-0 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="9" r="2.5" stroke-linecap="round"/>
                </svg>
                <div>
                  <span class="font-semibold text-[var(--color-navy)]">{county}</span>
                  <span class="text-[var(--color-text-muted)] text-sm ml-2">{cities}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl overflow-hidden border border-[var(--color-border)] shadow-md">
          <img
            src="/images/service-areas/houston-service-area.png"
            alt="Surgiquip Solutions service territory map — Greater Houston and Southeast Texas"
            width="1024"
            height="1024"
            loading="lazy"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Facility types -->
  <section class="py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Facilities We Serve</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Built for Houston Healthcare</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          From large health systems to independent surgery centers — our team is experienced with the equipment and compliance requirements of every Houston facility type.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {facilities.map((f) => (
          <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 hover:shadow-md hover:border-[var(--color-blue)] transition">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" set:html={f.icon} />
            </div>
            <h3 class="font-bold text-[var(--color-navy)] mb-2">{f.name}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="container-x py-16">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Offer</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Full-Scope OR Services in Houston</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2">
      {services.map((s) => (
        <a href={s.href} class="group block bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] p-8 hover:border-[var(--color-blue)] hover:shadow-md transition">
          <h3 class="font-display text-xl font-bold text-[var(--color-navy)] group-hover:text-[var(--color-blue)] transition mb-3">{s.title}</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed text-sm">{s.blurb}</p>
          <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)]">
            Learn more
            <svg class="w-4 h-4 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Location & Contact -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="grid gap-12 lg:grid-cols-2 items-start">
        <div>
          <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Houston Office</div>
          <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] mb-6">
            Based in Houston — Serving the Texas Medical Center and Beyond
          </h2>
          <address class="not-italic space-y-4 text-[var(--color-text-muted)]">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="9" r="2.5" stroke-linecap="round"/>
              </svg>
              <div>
                <div class="font-medium text-[var(--color-text)]">{site.address.street}</div>
                <div>{site.address.city}, {site.address.region} {site.address.postalCode}</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 shrink-0 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/>
              </svg>
              <a href={`tel:${site.phoneE164}`} class="font-semibold text-[var(--color-navy)] hover:text-[var(--color-blue)]">{site.phone}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 shrink-0 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="22,6 12,13 2,6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <a href={`mailto:${site.email}`} class="hover:text-[var(--color-blue)]">{site.email}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 shrink-0 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10" stroke-linecap="round"/>
                <polyline points="12 6 12 12 16 14" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{site.hours}</span>
            </div>
          </address>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact" class="btn-primary">Contact Our Team</a>
            <a href="/projects" class="btn-outline">View Houston Projects</a>
          </div>
        </div>

        <!-- Google Maps embed -->
        <div class="rounded-xl overflow-hidden border border-[var(--color-border)] shadow-sm">
          <iframe
            title="Surgiquip Solutions — 10653 Kinghurst Drive, Houston, TX 77099"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3468.6!2d-95.5521!3d29.6820!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjnCsDQwJzU1LjIiTiA5NcKwMzMnMDcuNiJX!5e0!3m2!1sen!2sus!4v1719350000000!5m2!1sen!2sus"
            width="100%"
            height="320"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Related areas -->
  <section class="container-x py-12">
    <div class="text-center mb-8">
      <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Also Serving the Greater Region</h2>
      <p class="mt-2 text-[var(--color-text-muted)]">Surgiquip's service territory extends across Southeast Texas and neighboring markets.</p>
    </div>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/service-areas/southeast-texas" class="group flex items-center gap-2 px-6 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-blue)] hover:shadow-sm transition bg-white">
        <svg class="w-5 h-5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="9" r="2.5" stroke-linecap="round"/>
        </svg>
        <span class="font-medium text-[var(--color-navy)] group-hover:text-[var(--color-blue)]">Southeast Texas Service Area →</span>
      </a>
      <a href="/service-areas" class="group flex items-center gap-2 px-6 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-blue)] hover:shadow-sm transition bg-white">
        <svg class="w-5 h-5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke-linecap="round"/>
          <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke-linecap="round"/>
        </svg>
        <span class="font-medium text-[var(--color-navy)] group-hover:text-[var(--color-blue)]">All Service Areas →</span>
      </a>
    </div>
  </section>

  <CTASection
    heading="Need Surgical Equipment Service in Houston?"
    subhead="Call us or submit a quote request — our team responds within one business day. Faster for urgent service calls."
    primaryLabel="Request a Quote"
    secondaryLabel="Call (713) 681-6362"
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
