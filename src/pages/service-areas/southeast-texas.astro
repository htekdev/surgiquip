---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer for Southeast Texas — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers across Beaumont, Galveston, Victoria, and the greater Gulf Coast region.',
  url: `${site.url}/service-areas/southeast-texas`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'State', name: 'Texas' },
    { '@type': 'City', name: 'Beaumont', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Galveston', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Victoria', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Corpus Christi', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Jefferson County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Orange County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Galveston County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Victoria County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  sameAs: [site.social.linkedin],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Southeast Texas', item: `${site.url}/service-areas/southeast-texas` },
  ],
};

const markets = [
  {
    city: 'Beaumont / Port Arthur',
    county: 'Jefferson & Orange Counties',
    desc: 'Southeast Texas anchor market. Serving Baptist Hospitals of Southeast Texas, CHRISTUS Health Southeast Texas, and surgery centers across the Golden Triangle.',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5" fill="none"/><polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="1.5" fill="none"/>',
  },
  {
    city: 'Galveston / League City',
    county: 'Galveston County',
    desc: "UTMB Health and the growing League City / Clear Lake hospital corridor — within same-day service range from Surgiquip's Houston base.",
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M2 12h20" stroke="currentColor" stroke-width="1.5"/><path d="M12 2a15.3 15.3 0 010 20" stroke="currentColor" stroke-width="1.5"/>',
  },
  {
    city: 'Victoria',
    county: 'Victoria County',
    desc: "DeTar Healthcare System and Victoria's regional health network — Surgiquip serves facilities here with planned service visits and rapid parts fulfillment.",
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 12h6M12 9v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  },
  {
    city: 'Corpus Christi',
    county: 'Nueces County',
    desc: 'CHRISTUS Spohn Health System and growing ASC market along the Coastal Bend — covered for equipment sales and scheduled service.',
    icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  {
    city: 'Lufkin / Nacogdoches',
    county: 'Angelina & Nacogdoches Counties',
    desc: 'Woodland Heights Medical Center and CHI St. Luke\'s Health — Deep East Texas hospitals supported with OR equipment programs and PM services.',
    icon: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/>',
  },
  {
    city: 'Lake Charles, LA',
    county: 'Calcasieu Parish (Louisiana)',
    desc: 'Cross-state service for CHRISTUS Ochsner Lake Area and neighboring hospitals just across the Texas border.',
    icon: '<path d="M9 20H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v3M9 12h2M9 16h2M13 12h6M13 16h6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
  },
];

const capabilities = [
  ['Surgical Tables', 'Skytron, full line — flat to 7-section specialty configurations'],
  ['Surgical Lights', 'Single and dual-head OR lights, endoscopic and hybrid configurations'],
  ['Equipment Booms', 'Single, dual, and AMSCO boom systems — OR and ICU configurations'],
  ['OR Installation', 'Turnkey builds — we coordinate the full OR equipment program'],
  ['Service & Repair', 'Factory-trained field service with regional parts inventory'],
  ['Preventive Maintenance', 'Annual and semi-annual PM programs with JC-compliant documentation'],
  ['Capital Planning', 'Multi-year OR equipment lifecycle planning for budget cycles'],
  ['Emergency Response', '24-hour critical call support for acute equipment failures'],
];
---

<BaseLayout
  title="OR Equipment Southeast Texas | Surgiquip Solutions"
  description="Authorized Skytron dealer for Southeast Texas. OR equipment sales, installation, service, and PM for hospitals and ASCs from Beaumont to Corpus Christi."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/southeast-texas`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Southeast Texas</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Service Area</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment for Southeast Texas
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        The authorized Skytron dealer for Southeast Texas — serving hospitals, surgery centers, and specialty clinics from Houston to Beaumont, Galveston, Victoria, and the Gulf Coast for over 43 years.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/>
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Territory intro -->
  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
    <div>
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Authorized Territory</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
        Skytron's Authorized Dealer for Southeast Texas
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        Surgiquip Solutions is the exclusive Skytron dealer for Southeast Texas — a territory that spans from Greater Houston east to Beaumont and Orange, south to Galveston and the Gulf Coast, and southwest toward Victoria and Corpus Christi.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        This isn't a regional sales rep arrangement. Surgiquip has operated out of Houston since 1983 — 43 years of building relationships with facilities directors, biomedical engineers, OR managers, and capital planning teams across the region. We know the facilities, the equipment, and the regulatory environment.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        For hospital systems with facilities across Southeast Texas, we provide a single-vendor program for Skytron equipment purchasing, installation, and ongoing maintenance — simplifying procurement, standardizing documentation, and reducing the vendor coordination burden on your biomedical team.
      </p>
    </div>
    <div class="rounded-xl overflow-hidden border border-[var(--color-border)] shadow-md">
      <img
        src="/images/service-areas/houston-service-area.webp"
        alt="Surgiquip Solutions service territory — Southeast Texas and Greater Houston service area map"
        width="1024"
        height="1024"
        loading="lazy"
        class="w-full h-auto"
      />
    </div>
    </div>
  </section>

  <!-- Market coverage -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Coverage Area</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Markets We Serve</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          From the Texas Medical Center to the Gulf Coast and into Louisiana — Surgiquip covers the full Southeast Texas healthcare corridor.
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {markets.map((m) => (
          <div class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:border-[var(--color-blue)] hover:shadow-md transition">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 shrink-0 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)]">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" set:html={m.icon} />
              </div>
              <div>
                <h3 class="font-bold text-[var(--color-navy)]">{m.city}</h3>
                <div class="text-xs text-[var(--color-blue)] font-semibold mb-2">{m.county}</div>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities table -->
  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Deliver</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">
          Full OR Equipment Lifecycle — Across the Region
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Whether your Southeast Texas facility needs new OR equipment, emergency repair on a Skytron table, or a multi-year preventive maintenance contract, Surgiquip delivers the same factory-level expertise that Houston's largest health systems rely on.
        </p>
        <div class="mt-6 grid grid-cols-2 gap-4">
          {[
            ['43 Years', 'in Southeast Texas'],
            ['500+', 'Facilities served'],
            ['Skytron', 'Authorized dealer'],
            ['A+ BBB', 'Accredited business'],
          ].map(([val, label]) => (
            <div class="p-4 bg-[var(--color-surface-alt)] rounded-lg border border-[var(--color-border)] text-center">
              <div class="font-display text-2xl font-bold text-[var(--color-navy)]">{val}</div>
              <div class="text-xs text-[var(--color-text-muted)] mt-1">{label}</div>
            </div>
          ))}
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/services" class="btn-primary">View All Services</a>
          <a href="/products" class="btn-outline">Browse Equipment</a>
        </div>
      </div>
      <div class="bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] p-6">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-4">Equipment & Services Available</div>
        <ul class="space-y-3">
          {capabilities.map(([cap, detail]) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <span class="font-semibold text-[var(--color-navy)]">{cap}</span>
                <span class="text-sm text-[var(--color-text-muted)]"> — {detail}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Related areas -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Houston Is Our Home Base</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">Surgiquip is headquartered in Houston — the heart of the Southeast Texas service territory.</p>
      </div>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/service-areas/houston-tx" class="group flex items-center gap-2 px-6 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-blue)] hover:shadow-sm transition bg-white">
          <svg class="w-5 h-5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="9" r="2.5" stroke-linecap="round"/>
          </svg>
          <span class="font-medium text-[var(--color-navy)] group-hover:text-[var(--color-blue)]">Houston, TX Service Area →</span>
        </a>
        <a href="/service-areas" class="group flex items-center gap-2 px-6 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-blue)] hover:shadow-sm transition bg-white">
          <svg class="w-5 h-5 text-[var(--color-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke-linecap="round"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" stroke-linecap="round"/>
          </svg>
          <span class="font-medium text-[var(--color-navy)] group-hover:text-[var(--color-blue)]">All Service Areas →</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    heading="Serving a Southeast Texas Healthcare Facility?"
    subhead="Get in touch with our team — we know the region and we know Skytron. Same-day response for urgent service requests."
    primaryLabel="Request a Quote"
    secondaryLabel="Call (713) 681-6362"
    secondaryHref={`tel:${site.phoneE164}`}
  />
</BaseLayout>
