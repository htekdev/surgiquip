---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  description:
    'Authorized Skytron dealer serving Pearland, TX hospitals and surgery centers since 1983. OR equipment sales, installation, service, and preventive maintenance in Brazoria County.',
  url: `${site.url}/service-areas/pearland-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 29.5636,
    longitude: -95.2861,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Pearland', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Brazoria County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Pearland, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin, site.social.youtube],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Pearland, TX', item: `${site.url}/service-areas/pearland-tx` },
  ],
};
---
<BaseLayout
  title="Surgical Equipment — Pearland, TX | Surgiquip Solutions"
  description="Surgiquip Solutions serves Pearland, TX — authorized Skytron dealer for Brazoria County. OR equipment sales, ER bay outfitting, service and preventive maintenance. Memorial Hermann Pearland reference site."
  schema={[localBusinessSchema, breadcrumbSchema]}
>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Pearland, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Brazoria County</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl">
        Surgical Equipment Service — Pearland, TX
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-xl">
        Authorized Skytron dealer serving Brazoria County healthcare facilities since 1983.
        Surgiquip has equipped Pearland-area facilities including Memorial Hermann Pearland.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="inline-flex items-center gap-2 bg-[var(--color-blue)] hover:bg-[var(--color-blue-light)] text-white font-semibold px-6 py-3 rounded-lg transition">
          Request Quote
        </a>
        <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 border border-white/30 hover:border-white text-white font-semibold px-6 py-3 rounded-lg transition">
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ── Reference Installation ─────────────────────────────────────────────── -->
  <section class="bg-[var(--color-surface-alt)] py-14 border-b border-[var(--color-border)]">
    <div class="container-x">
      <div class="max-w-4xl mx-auto">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Reference Installation</div>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-[var(--color-navy)] mb-4">
          Memorial Hermann Pearland
        </h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Surgiquip Solutions outfitted Memorial Hermann Pearland with Center Mount Booms, Aurora LED surgical
          lighting, warming and storage cabinets, and portable exam lights across 3 emergency room bays.
          The project demonstrates Surgiquip's flexibility — from full hospital builds to targeted
          department-level equipment programs for growing Brazoria County facilities.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Markets Grid ───────────────────────────────────────────────────────── -->
  <section class="container-x py-16">
    <div class="text-center mb-10">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Brazoria County Healthcare</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {[
        { name: 'Hospitals', desc: 'Full-service OR equipment programs for Pearland-area acute care hospitals.' },
        { name: 'Emergency Departments', desc: 'ER bay outfitting — booms, lighting, warming cabinets, and portable exam lights.' },
        { name: 'Surgery Centers', desc: 'Right-sized OR packages for Brazoria County ASCs.' },
        { name: 'Specialty Clinics', desc: 'Procedure room equipment for specialty practices in the Pearland corridor.' },
      ].map((m) => (
        <div class="bg-[var(--color-surface-alt)] rounded-xl border border-[var(--color-border)] p-6">
          <h3 class="font-bold text-[var(--color-navy)] mb-2">{m.name}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Services ──────────────────────────────────────────────────────────── -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Services in Pearland</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          { href: '/services/equipment-sales', title: 'Equipment Sales', body: 'Authorized Skytron dealer and multi-brand surgical equipment provider.' },
          { href: '/services/or-installation', title: 'OR Installation', body: 'Turnkey OR builds and targeted department equipment installations.' },
          { href: '/services/service-and-repair', title: 'Service & Repair', body: 'Factory-certified technicians serving Brazoria County facilities.' },
          { href: '/services/preventive-maintenance', title: 'Preventive Maintenance', body: 'Scheduled PM programs with Joint Commission-ready documentation.' },
          { href: '/products/skytron', title: 'Skytron Products', body: 'Aurora LED lights, surgical tables, and ceiling-mount booms.' },
          { href: '/projects', title: 'Project Portfolio', body: 'See real installations across Pearland, Brazoria, and Southeast Texas.' },
        ].map((s) => (
          <a href={s.href} class="bg-white rounded-xl border border-[var(--color-border)] p-6 hover:shadow-md transition group">
            <h3 class="font-bold text-[var(--color-navy)] mb-2 group-hover:text-[var(--color-blue)] transition">{s.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{s.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Serving Pearland & Brazoria County"
    subhead={`Contact Surgiquip Solutions at ${site.phone} — authorized Skytron dealer for Southeast Texas since 1983.`}
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Contact Us"
    secondaryHref="/contact"
  />
</BaseLayout>
