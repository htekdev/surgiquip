---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `${site.url}#organization`,
  name: site.brand,
  alternateName: 'Surgiquip Solutions',
  description:
    'Authorized Skytron dealer serving Austin, TX and Central Texas — OR equipment sales, installation, service, and preventive maintenance for hospitals and surgery centers in Travis, Williamson, Hays, and Bastrop counties.',
  url: `${site.url}/service-areas/austin-tx`,
  telephone: site.phone,
  email: site.email,
  foundingDate: '1983',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 30.2672,
    longitude: -97.7431,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:30',
    closes: '16:30',
  },
  areaServed: [
    { '@type': 'City', name: 'Austin', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Round Rock', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Georgetown', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Cedar Park', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Kyle', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'City', name: 'Buda', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Travis County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Williamson County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Hays County', containedInPlace: { '@type': 'State', name: 'Texas' } },
    { '@type': 'County', name: 'Bastrop County', containedInPlace: { '@type': 'State', name: 'Texas' } },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'OR Equipment & Services — Austin, TX',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Surgical Equipment Sales' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OR Installation & Integration' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Equipment Service & Repair' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Preventive Maintenance Programs' } },
    ],
  },
  sameAs: [site.social.linkedin],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas` },
    { '@type': 'ListItem', position: 3, name: 'Austin, TX', item: `${site.url}/service-areas/austin-tx` },
  ],
};

const services = [
  {
    href: '/services/equipment-sales',
    title: 'Surgical Equipment Sales',
    blurb:
      'Authorized Skytron dealer for Austin and Central Texas. Surgical tables, OR lighting systems, and equipment booms for Dell Seton Medical Center, St. David\'s HealthCare, Ascension Seton, Baylor Scott & White, and Austin-area surgery centers.',
  },
  {
    href: '/services/or-installation',
    title: 'OR Installation & Integration',
    blurb:
      'Turnkey OR installations for new builds and renovations across the Austin metro — from coordination with your GC, architect, and A/E team through commissioning, staff training, and go-live support. Hybrid OR integration experience included.',
  },
  {
    href: '/services/service-and-repair',
    title: 'Service & Repair',
    blurb:
      'Factory-trained technicians serving Austin, Round Rock, Georgetown, Cedar Park, and surrounding counties. Emergency and scheduled service for Skytron and major OR equipment brands across Travis, Williamson, and Hays counties.',
  },
  {
    href: '/services/preventive-maintenance',
    title: 'Preventive Maintenance',
    blurb:
      'Structured PM programs for surgical tables, overhead lights, and ceiling booms — with documentation formatted for Joint Commission and DNV GL survey readiness across Central Texas facilities.',
  },
];

const austinStats = [
  { value: '43 Years', label: 'Texas OR expertise', sub: 'Since 1983' },
  { value: '4 Counties', label: 'Central Texas territory', sub: 'Travis · Williamson · Hays · Bastrop' },
  { value: '24hr', label: 'Emergency response', sub: 'For critical equipment' },
  { value: 'Factory', label: 'Certified technicians', sub: 'Skytron authorized' },
];

const markets = [
  {
    city: 'Austin / Travis County',
    county: 'Travis County',
    desc: "Central Texas's premier healthcare market. Serving Dell Seton Medical Center at The University of Texas, St. David's Medical Center (Round Rock, South Austin, Georgetown, Cedar Park campuses), Ascension Seton (Flagship + Northwest + Southwest campuses), Baylor Scott & White Medical Center — Round Rock, and Austin Surgical Hospital — one of the fastest-growing OR capital equipment markets in Texas.",
  },
  {
    city: 'Round Rock / Williamson County',
    county: 'Williamson County',
    desc: "One of the highest-growth healthcare sub-markets in Texas. Baylor Scott & White Medical Center — Round Rock (Level II Trauma), St. David's Round Rock Medical Center, and a rapidly expanding landscape of outpatient surgical centers driven by Williamson County's population surge along the US-79 and I-35 corridors.",
  },
  {
    city: 'Kyle / Buda / Hays County',
    county: 'Hays County',
    desc: 'Ascension Seton Hays Medical Center (Kyle) and growing outpatient surgical development in one of Texas\'s fastest-expanding counties. Hays County\'s healthcare build-out is accelerating — Surgiquip provides capital equipment and service support for new OR installations and existing facility expansions.',
  },
  {
    city: 'Georgetown / Cedar Park / Bastrop County',
    county: 'Williamson · Bastrop Counties',
    desc: "Georgetown Hospital (Ascension Seton), St. David's Georgetown Hospital, and Cedar Park Regional Medical Center — covering Williamson County's northern corridor and eastern Bastrop County. Accessible for service calls, equipment consultations, and OR planning support as these communities continue rapid healthcare infrastructure expansion.",
  },
];
---

<BaseLayout
  title="Austin, TX Surgical Equipment — Sales, Service & OR Installation | Surgiquip Solutions"
  description="Surgiquip Solutions serves hospitals and surgery centers in Austin and Central Texas — authorized Skytron dealer for surgical tables, OR lighting, equipment booms, service, and preventive maintenance across Travis, Williamson, Hays, and Bastrop counties."
  schema={[localBusinessSchema, breadcrumbSchema]}
  canonical={`${site.url}/service-areas/austin-tx`}
>
  <!-- Hero -->
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
        <a href="/" class="hover:text-white/90">Home</a>
        <span class="mx-2">/</span>
        <a href="/service-areas" class="hover:text-white/90">Service Areas</a>
        <span class="mx-2">/</span>
        <span class="text-white/90">Austin, TX</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Central Texas</div>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment for Austin &amp; Central Texas
      </h1>
      <p class="mt-6 text-xl text-white/85 max-w-2xl leading-relaxed">
        Surgiquip Solutions serves hospitals, surgery centers, and specialty clinics across Austin and Central Texas — authorized Skytron dealer for OR tables, lighting systems, equipment booms, and full-lifecycle service since 1983.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary px-7 py-3.5">Request a Quote</a>
        <a
          href={`tel:${site.phoneE164}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[var(--color-navy-dark)] text-white">
    <div class="container-x py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 divide-y md:divide-y-0 md:divide-x divide-white/10">
        {austinStats.map((s) => (
          <div class="text-center py-2 first:pt-0 last:pb-0 md:py-0">
            <div class="font-display text-2xl font-bold text-white">{s.value}</div>
            <div class="text-xs text-white/70 mt-1 leading-tight">{s.label}</div>
            <div class="text-xs text-white/50 mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Markets grid -->
  <section class="container-x py-16">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Coverage Area</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Austin &amp; Central Texas Markets</h2>
      <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
        From Travis County's major academic medical centers to Williamson and Hays County's high-growth hospital expansions — Surgiquip provides authorized OR equipment service across the Central Texas corridor.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
      {markets.map((m) => (
        <div class="bg-white border border-[var(--color-border)] rounded-xl p-7">
          <div class="flex items-start gap-3 mb-3">
            <div class="w-9 h-9 rounded-full bg-[var(--color-navy)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-[var(--color-navy)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--color-navy)] text-base">{m.city}</h3>
              <div class="text-xs text-[var(--color-blue)] font-semibold mt-0.5">{m.county}</div>
            </div>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services in this market -->
  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Provide</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Services for Austin Facilities</h2>
        <p class="mt-3 text-[var(--color-text-muted)] max-w-xl mx-auto">
          Full-lifecycle OR equipment support for Central Texas hospitals and surgery centers — from initial capital equipment procurement through ongoing preventive maintenance.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        {services.map((s) => (
          <a
            href={s.href}
            class="group block bg-white border border-[var(--color-border)] rounded-xl p-7 hover:border-[var(--color-blue)] hover:shadow-md transition"
          >
            <h3 class="font-bold text-[var(--color-navy)] text-lg group-hover:text-[var(--color-blue)] transition mb-2">{s.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{s.blurb}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-[var(--color-blue)]">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Surgiquip for Austin -->
  <section class="container-x py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3 text-center">Why Surgiquip</div>
      <h2 class="font-display text-3xl font-bold text-[var(--color-navy)] text-center mb-8">
        Houston-Based. Central Texas Ready.
      </h2>
      <div class="grid gap-5 md:grid-cols-3">
        {[
          {
            icon: '<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
            title: 'Authorized Skytron Dealer',
            desc: 'OEM parts, factory training, and full warranty coverage for Austin health systems — not a third-party broker.',
          },
          {
            icon: '<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
            title: '24-Hour Emergency Response',
            desc: 'When OR equipment fails before a full schedule, you need a service partner who responds — not a call center routing system.',
          },
          {
            icon: '<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
            title: 'Survey-Ready Documentation',
            desc: 'PM records formatted for Joint Commission and DNV GL audits — no last-minute paperwork scrambles before survey.',
          },
        ].map((item) => (
          <div class="bg-[var(--color-surface-alt)] rounded-xl p-6 text-center border border-[var(--color-border)]">
            <div class="w-12 h-12 rounded-full bg-[var(--color-navy)]/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-[var(--color-navy)]" viewBox="0 0 24 24" fill="none" set:html={item.icon} aria-hidden="true" />
            </div>
            <h3 class="font-bold text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources cross-links -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-x">
      <div class="text-center mb-8">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Resources</div>
        <h2 class="font-display text-2xl font-bold text-[var(--color-navy)]">Useful for Austin Facilities Teams</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3 max-w-4xl mx-auto">
        {[
          {
            href: '/blog/hybrid-or-planning-guide-texas-hospitals',
            title: 'Hybrid OR Planning Guide',
            desc: 'Infrastructure requirements, equipment integration, and vendor selection criteria for Texas hospitals planning a hybrid OR build or renovation.',
          },
          {
            href: '/blog/or-installation-planning-guide-texas',
            title: 'OR Installation Planning Guide',
            desc: 'What Texas hospitals need to know before breaking ground on an OR renovation or new build — timelines, coordination, and equipment decisions.',
          },
          {
            href: '/services/preventive-maintenance',
            title: 'Preventive Maintenance Programs',
            desc: 'Structured PM plans for surgical tables, OR lights, and equipment booms — survey documentation included.',
          },
        ].map((r) => (
          <a
            href={r.href}
            class="group block bg-white border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-blue)] hover:shadow-md transition"
          >
            <h3 class="font-bold text-[var(--color-navy)] text-sm group-hover:text-[var(--color-blue)] transition mb-2">{r.title}</h3>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">{r.desc}</p>
            <span class="inline-flex items-center gap-1 mt-3 text-xs font-semibold text-[var(--color-blue)]">
              Read more
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Have an OR Equipment Need in Austin?"
    subhead="Tell us what you need — we'll confirm coverage and respond within one business day."
    primaryLabel="Contact Our Team"
    primaryHref="/contact"
    secondaryLabel="Request a Quote"
  />
</BaseLayout>
