---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import FAQSection from '~/components/FAQSection.astro';
import { site } from '~/data/site';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Medical Equipment Sales',
  provider: { '@id': `${site.url}#organization` },
  description: 'Authorized medical equipment sales including Skytron surgical tables, lights, booms, and OR integration. Serving Texas healthcare facilities since 1983.',
  areaServed: [{ '@type': 'State', name: 'Texas' }],
  serviceType: 'Medical Equipment Sales',
  url: `${site.url}/services/equipment-sales`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site.url}/services` },
    { '@type': 'ListItem', position: 3, name: 'Equipment Sales', item: `${site.url}/services/equipment-sales` },
  ],
};

const offerings = [
  {
    icon: '<path d="M3 9h18M3 9a2 2 0 012-2h14a2 2 0 012 2M3 9v9a2 2 0 002 2h14a2 2 0 002-2V9M9 13h6M12 11v4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
    title: 'Skytron Surgical Tables',
    desc: 'The full Skytron line — multi-articulating tables with memory positioning, radiolucent tops, and C-arm compatibility for the complexity of modern surgical procedures.',
  },
  {
    icon: '<circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 2v2M12 14v8M5 8H3M21 8h-2M7 5l-1.5-1.5M17 5l1.5-1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Surgical Lighting Systems',
    desc: 'Advanced LED surgical lights with adjustable color temperature (3,500–5,000K), shadow management, and optional integrated camera for documentation and remote viewing.',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 9h6M9 12h6M9 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Equipment Booms & Pendants',
    desc: 'Ceiling-mounted surgical booms with integrated gas, electrical, and data connections — freeing your OR floor and streamlining workflow for every case.',
  },
  {
    icon: '<rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'OR Integration Systems',
    desc: 'Complete hybrid OR packages — video switching, 4K displays, room integration, and unified control of all room systems in one seamless surgical environment.',
  },
  {
    icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Multi-Brand Portfolio',
    desc: 'Beyond Skytron, we partner with Wassenburg, Infinitus, WEG, and other leading manufacturers — a complete portfolio covering every stage of surgical suite setup and maintenance.',
  },
  {
    icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
    title: 'BBB A+ Trusted Partner',
    desc: 'Every purchase is backed by a BBB A+ accredited business with 43 years of Houston healthcare relationships and no-compromise quality standards.',
  },
];

const processSteps = [
  ['Needs Assessment', "We review your procedure volume, room dimensions, and surgeon preferences."],
  ['Equipment Specification', "We recommend the right model and accessories — no overselling."],
  ['Pricing & Procurement', "Direct factory pricing with transparent, itemized quotes. No surprises."],
  ['Installation', "Factory-certified installation coordinated around your OR schedule."],
  ['Training & Go-Live', "Staff orientation included. We don't leave until your team is confident."],
  ['Ongoing Service', "PM programs and rapid repair from the same team, long-term."],
];

const whyItems = [
  'Authorized Skytron dealer — direct factory support and pricing',
  'Factory-trained application specialists for product selection',
  'Full lifecycle coverage: sales, install, training, ongoing service',
  'Relationships with Texas hospital networks built over 43 years',
  'No-pressure consultation — we match equipment to your needs',
  'Same team handles your install and future service calls',
];

// Equipment Sales FAQ — 4 questions for FAQPage schema + visible accordion.
const salesFAQs = [
  {
    q: 'Is Surgiquip an authorized Skytron dealer?',
    a: 'Yes. Surgiquip Solutions has been the Authorized Skytron dealer for South Texas since the 1980s. Authorization means direct factory pricing, factory-trained application specialists who know every product configuration, access to OEM parts, and warranty-backed service — not the secondhand support you get from a reseller.',
  },
  {
    q: 'What surgical equipment brands does Surgiquip carry?',
    a: 'Our primary line is Skytron — the full catalog of surgical tables, overhead lights, ceiling-mount booms, and OR integration systems. We also partner with Wassenburg, Infinitus, WEG, and other leading manufacturers, giving you a single source for comprehensive OR setup.',
  },
  {
    q: 'Do you sell certified pre-owned surgical equipment?',
    a: 'Yes. We periodically have certified pre-owned Skytron equipment — tables, lights, and accessories — fully refurbished and recertified to manufacturer specifications. Pre-owned Skytron is an excellent option for facilities that want the reliability of a premium brand at a reduced capital cost. Contact us to ask about current inventory.',
  },
  {
    q: 'What support does Surgiquip provide after an equipment purchase?',
    a: `Every purchase includes the full lifecycle: factory-certified installation coordinated around your OR schedule, hands-on staff orientation at handoff, access to our preventive maintenance programs, and rapid service and repair by the same factory-trained technicians who installed the equipment. You're not buying a product — you're starting a service relationship. Call us at <a href="tel:${site.phoneE164}" class="text-[var(--color-blue)] underline underline-offset-2 hover:opacity-80">${site.phone}</a> to discuss your equipment needs.`,
  },
];

const salesFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: salesFAQs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a.replace(/<[^>]+>/g, ''),
    },
  })),
};
---
<BaseLayout
  title="Medical Equipment Sales | Surgiquip Solutions Houston TX"
  description="Authorized Skytron dealer for South Texas. Surgical tables, lights, booms, OR integration, and multi-brand equipment. 43 years serving Texas."
  schema={[serviceSchema, breadcrumbSchema, salesFaqSchema]}
  preloadImage="/images/services/equipment-sales-hero.webp"
>
  <section class="bg-[var(--color-navy)] text-white overflow-hidden">
    <div class="container-x py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
            <a href="/" class="hover:text-white/90">Home</a>
            <span class="mx-2">/</span>
            <a href="/services" class="hover:text-white/90">Services</a>
          </nav>
          <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Services</div>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
            Medical Equipment Sales
          </h1>
          <p class="mt-6 text-xl text-white/85 max-w-xl leading-relaxed">
            Authorized dealer for Skytron — the gold standard in surgical technology — plus partnerships with Wassenburg, Infinitus, WEG, and 43 years of Houston healthcare expertise. We don't just sell equipment; we build operating rooms that last.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/quote" class="btn-primary px-7 py-3.5">Request Equipment Quote</a>
            <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
              Call {site.phone}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/services/equipment-sales-hero.webp"
            alt="Surgiquip medical equipment showroom — surgical tables, lights, and OR systems in Houston TX"
            class="rounded-2xl shadow-2xl object-cover w-full aspect-[4/3]"
            loading="eager"
            decoding="async"
            width="768"
            height="576"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">What We Offer</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
        The Right Equipment, Expertly Specified
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        For {site.yearsInBusiness} years, Surgiquip Solutions has equipped Texas hospitals, surgery centers, and specialty clinics with the instruments and room systems their surgical teams depend on. Our Skytron partnership as the exclusive authorized dealer for Southeast Texas means direct factory expertise — not a commodity reseller.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        We work with your biomedical team, OR committee, and facilities staff to evaluate your surgical volume, procedure mix, and facility constraints before recommending any equipment. Your needs drive the specification.
      </p>
    </div>
  </section>

  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Product Lines</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">Equipment We Sell and Support</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {offerings.map((item) => (
          <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 hover:shadow-md hover:border-[var(--color-blue)] transition">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Surgiquip</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">
          More Than a Vendor — A Long-Term Partner
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          When you purchase equipment through Surgiquip, you're establishing a service relationship with the same team that installs it, trains your staff, and maintains it for the life of the equipment.
        </p>
        <ul class="mt-6 space-y-3">
          {whyItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[var(--color-blue)] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none">
                <path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-[var(--color-text-muted)] text-sm">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-[var(--color-surface-alt)] rounded-xl p-8 border border-[var(--color-border)]">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-5">Our Process</div>
        <ol class="space-y-5">
          {processSteps.map(([step, desc], i) => (
            <li class="flex gap-4">
              <div class="shrink-0 w-8 h-8 rounded-full bg-[var(--color-blue)] text-white flex items-center justify-center text-sm font-bold">{i + 1}</div>
              <div>
                <div class="font-semibold text-[var(--color-navy)]">{step}</div>
                <div class="text-sm text-[var(--color-text-muted)] mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <FAQSection
    eyebrow="Equipment Sales FAQ"
    heading="Common Questions About Buying Surgical Equipment"
    items={salesFAQs}
    bg="white"
  />

  <CTASection
    heading="Ready to Spec Your Next OR?"
    subhead="Our team will walk through your facility's needs, recommend the right equipment, and provide a transparent quote — no obligation."
  />
</BaseLayout>

