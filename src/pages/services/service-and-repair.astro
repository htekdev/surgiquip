---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Medical Equipment Service & Repair',
  provider: { '@id': `${site.url}#organization` },
  description: 'Factory-trained technicians for medical equipment repair, maintenance, and emergency support. 24-hour response for Texas healthcare facilities.',
  areaServed: [{ '@type': 'State', name: 'Texas' }],
  serviceType: 'Medical Equipment Repair',
  url: `${site.url}/services/service-and-repair`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site.url}/services` },
    { '@type': 'ListItem', position: 3, name: 'Service & Repair', item: `${site.url}/services/service-and-repair` },
  ],
};

const capabilities = [
  {
    icon: '<path d="M14.7 6.3a4 4 0 00-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 005.4-5.4l-3 3-2.4-2.4 3-3z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>',
    title: 'Surgical Table Repair',
    desc: 'Skytron and all major table brands — hydraulic systems, positioning motors, accessory hardware, and electronic controls. Factory-authorized parts and procedures.',
  },
  {
    icon: '<circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Surgical Light Repair',
    desc: 'LED module replacement, power supply troubleshooting, ceiling mount inspection, and intensity calibration for all major surgical light brands.',
  },
  {
    icon: '<rect x="3" y="8" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 8V6a3 3 0 016 0v2M12 13v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Equipment Boom Service',
    desc: 'Gas outlet testing, arm articulation inspection, electrical connection verification, and full boom recertification for Joint Commission readiness.',
  },
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: '24-Hour Emergency Response',
    desc: 'When your OR goes down, time matters. Our emergency line connects you to a factory-trained technician — 24 hours, 7 days a week, every day of the year.',
  },
  {
    icon: '<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Compliance Documentation',
    desc: 'Full service records, PM certificates, and regulatory documentation — everything your biomedical team needs for Joint Commission and DNV surveys.',
  },
  {
    icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Stocked Parts Inventory',
    desc: 'We maintain an on-hand parts inventory for Skytron and other key brands so common repairs ship same-day — no weeks-long backorder delays.',
  },
];

const responseProcess = [
  ['Call or Email', 'Reach our service line — a human answers during business hours; emergency line 24/7.'],
  ['Triage', 'We assess the issue over the phone to dispatch with the right parts and tools.'],
  ['Dispatch', 'A factory-trained technician is dispatched — same day for emergencies.'],
  ['Repair & Certification', 'Repair completed on-site where possible; full service report provided.'],
  ['Documentation', 'Compliance-ready service records delivered to your biomedical team.'],
];
---
<BaseLayout
  title="Medical Equipment Service & Repair | Surgiquip Solutions"
  description="Factory-trained technicians for surgical table, light, and boom repair in Texas. 24-hour emergency response. Authorized Skytron service center."
  schema={[serviceSchema, breadcrumbSchema]}
>
          </nav>
          <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Services</div>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
            Service & Repair
          </h1>
          <p class="mt-6 text-xl text-white/85 max-w-xl leading-relaxed">
            Factory-trained technicians, a stocked parts inventory, and a 24-hour emergency line — because a down OR table cannot wait until Monday.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/quote" class="btn-primary px-7 py-3.5">Schedule Service</a>
            <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
              Emergency: {site.phone}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/services/equipment-repair-hero.png"
            alt="Surgiquip factory-trained technician servicing OR equipment in a Texas hospital"
            class="rounded-2xl shadow-2xl object-cover w-full aspect-[4/3]"
            loading="eager"
            decoding="async"
            width="768"
            height="576"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Who We Service</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
        Expert Repair for the Modern OR
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        Our service technicians are factory-trained and certified — not generalists. Every repair uses manufacturer-approved parts, follows OEM procedures, and is documented for your compliance records. We've kept Texas ORs running for {site.yearsInBusiness} years.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        We service hospitals, ambulatory surgery centers, specialty clinics, and veterinary surgical facilities across Texas. Our Skytron authorization means direct access to parts, technical bulletins, and support that independent repair shops cannot access.
      </p>
    </div>
  </section>

  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Capabilities</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What We Repair & Service</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {capabilities.map((item) => (
          <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 hover:shadow-md hover:border-[var(--color-blue)] transition">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Response Protocol</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">
          From Call to Fixed — Fast
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          Our service process is designed around one principle: your OR should not be idle. We triage quickly, dispatch with the right parts, and complete repairs with full documentation — every time.
        </p>
        <div class="mt-6 inline-flex items-center gap-3 p-4 rounded-lg bg-[var(--color-surface-alt)] border border-[var(--color-border)]">
          <div class="w-10 h-10 rounded-full bg-[var(--color-blue)] text-white flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
          </div>
          <div>
            <div class="font-bold text-[var(--color-navy)] text-sm">24-Hour Emergency Line</div>
            <a href={`tel:${site.phoneE164}`} class="text-[var(--color-blue)] font-semibold">{site.phone}</a>
          </div>
        </div>
      </div>
      <div class="bg-[var(--color-surface-alt)] rounded-xl p-8 border border-[var(--color-border)]">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)] mb-5">Service Process</div>
        <ol class="space-y-5">
          {responseProcess.map(([step, desc], i) => (
            <li class="flex gap-4">
              <div class="shrink-0 w-8 h-8 rounded-full bg-[var(--color-blue)] text-white flex items-center justify-center text-sm font-bold">{i + 1}</div>
              <div>
                <div class="font-semibold text-[var(--color-navy)]">{step}</div>
                <div class="text-sm text-[var(--color-text-muted)] mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <CTASection
    heading="Equipment Down? Let's Fix It."
    subhead={`Call ${site.phone} for emergency service, or submit a service request online. Factory-trained technicians available 24 hours.`}
    primaryLabel="Schedule Service"
    secondaryLabel={`Call ${site.phone}`}
  />
</BaseLayout>
