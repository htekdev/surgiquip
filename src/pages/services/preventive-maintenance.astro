---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import FAQSection from '~/components/FAQSection.astro';
import { site } from '~/data/site';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Preventive Maintenance for Medical Equipment',
  provider: { '@id': `${site.url}#organization` },
  description: 'Planned preventive maintenance programs for surgical tables, lights, booms, washers, sterilizers, and OR equipment in Texas. Service reports and documentation included.',
  areaServed: [{ '@type': 'State', name: 'Texas' }],
  serviceType: 'Preventive Maintenance',
  url: `${site.url}/services/preventive-maintenance`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site.url}/services` },
    { '@type': 'ListItem', position: 3, name: 'Preventive Maintenance', item: `${site.url}/services/preventive-maintenance` },
  ],
};

const pmIncludes = [
  {
    icon: '<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>',
    title: 'Scheduled Inspections',
    desc: 'Quarterly, semi-annual, or annual inspection visits coordinated around your OR schedule — frequency matched to each piece of equipment.',
  },
  {
    icon: '<path d="M14.7 6.3a4 4 0 00-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 005.4-5.4l-3 3-2.4-2.4 3-3z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>',
    title: 'Parts Replacement',
    desc: 'Wear items replaced on a proactive schedule — filters, seals, cables, and hardware — before they become failure points.',
  },
  {
    icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Functional Testing',
    desc: 'Functional testing per manufacturer-recommended preventative maintenance schedules — documented before we leave.',
  },
  {
    icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
    title: 'Service Reports',
    desc: 'Detailed reports after every PM visit documenting what was inspected, tested, replaced, and recommended — ready for your biomedical records.',
  },
  {
    icon: '<rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Priority Scheduling',
    desc: 'PM contract clients receive priority dispatch for service calls — your repairs jump to the front of the queue.',
  },
  {
    icon: '<circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
    title: 'Equipment Lifecycle Planning',
    desc: 'We track equipment age and condition to provide proactive replacement recommendations — avoiding capital surprises.',
  },
];

// Preventive Maintenance FAQ — 4 questions for FAQPage schema + visible accordion.
const pmFAQs = [
  {
    q: 'What is included in a Surgiquip preventive maintenance program?',
    a: 'Every PM visit includes: scheduled inspections (quarterly, semi-annual, or annual, coordinated around your OR calendar), proactive replacement of wear parts before they become failure points, functional testing per manufacturer-recommended schedules, detailed service reports for your biomedical records, and priority dispatch status for any service calls between scheduled visits. We also provide equipment lifecycle planning so you can anticipate capital replacement needs.',
  },
  {
    q: 'How often should surgical equipment receive preventive maintenance?',
    a: 'Most manufacturers specify annual minimum intervals, with semi-annual or quarterly recommended for high-volume facilities. Surgiquip implements the factory-recommended intervals for all Skytron equipment and applies the same rigor to all other brands we maintain — so your PM records reflect manufacturer best practices.',
  },
  {
    q: 'Does your PM documentation satisfy Joint Commission and CMS requirements?',
    a: 'Yes. Our PM service reports and documentation are formatted to support Joint Commission and CMS requirements. Your biomedical director receives detailed records of every inspection, test, and parts replacement — ready for survey day.',
  },
  {
    q: 'What is the advantage of a PM contract over calling for repairs as-needed?',
    a: `PM contract clients receive scheduled visits, proactive parts replacement, detailed service reports, and priority dispatch status for service calls — repairs jump to the front of our queue. On-demand repair is reactive, typically costs more per event, and tends to happen at the worst possible time. Facilities with PM programs consistently see fewer unplanned OR cancellations and more predictable capital budgets. <a href="/quote" class="text-[var(--color-blue)] underline underline-offset-2 hover:opacity-80">Request a PM proposal</a> to see what a program costs for your facility.`,
  },
];

const pmFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pmFAQs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a.replace(/<[^>]+>/g, ''),
    },
  })),
};
---
<BaseLayout
  title="OR Equipment Preventive Maintenance | Surgiquip"
  description="Planned maintenance programs for surgical tables, lights, washers, sterilizers, and OR equipment in Texas. All brands serviced. Authorized Skytron service."
  schema={[serviceSchema, breadcrumbSchema, pmFaqSchema]}
  preloadImage="/images/services/preventive-maintenance-hero.webp"
>
  <section class="bg-[var(--color-navy)] text-white overflow-hidden">
    <div class="container-x py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <nav aria-label="Breadcrumb" class="text-xs text-white/60 mb-4">
            <a href="/" class="hover:text-white/90">Home</a>
            <span class="mx-2">/</span>
            <a href="/services" class="hover:text-white/90">Services</a>
            <span class="mx-2">/</span>
            <span class="text-white/90">Preventive Maintenance</span>
          </nav>
          <div class="text-xs font-bold tracking-widest uppercase text-white/70 mb-3">Services</div>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
            Preventive Maintenance
          </h1>
          <p class="mt-6 text-xl text-white/85 max-w-xl leading-relaxed">
            Maximize uptime, extend equipment life, and stay survey-ready with a managed PM program from Surgiquip — factory-trained technicians maintaining all brands of OR equipment across Texas.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/quote" class="btn-primary px-7 py-3.5">Request PM Proposal</a>
            <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-white/40 font-semibold text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.4 21 3 13.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .7-.2 1l-2.3 2.3z"/></svg>
              Call {site.phone}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/services/preventive-maintenance-hero.webp"
            alt="Surgiquip technician performing preventive maintenance on surgical equipment in Texas"
            class="rounded-2xl shadow-2xl object-cover w-full aspect-[4/3]"
            loading="eager"
            decoding="async"
            width="768"
            height="576"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="max-w-3xl">
      <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Why Planned Maintenance</div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--color-navy)]">
        Planned Beats Reactive — Every Time
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        Emergency repairs cost more, take longer, and happen at the worst possible time. A managed PM program with Surgiquip keeps your OR equipment performing at specification, your records survey-ready, and your capital budget predictable.
      </p>
      <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
        Our PM programs cover all brands of surgical equipment — whether we sold it, installed it, or inherited it from another provider. Skytron tables, surgical lights, equipment booms, washers, sterilizers, and hybrid OR systems — all maintained by factory-trained technicians who know the equipment inside and out.
      </p>
    </div>
  </section>

  <section class="bg-[var(--color-surface-alt)] py-16">
    <div class="container-x">
      <div class="text-center mb-12">
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">Program Inclusions</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">What's Included in Every PM Visit</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {pmIncludes.map((item) => (
          <div class="bg-white rounded-lg border border-[var(--color-border)] p-6 hover:shadow-md hover:border-[var(--color-blue)] transition">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt)] flex items-center justify-center text-[var(--color-navy)] mb-4">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-[var(--color-blue)] mb-3">How It Works</div>
        <h2 class="font-display text-3xl font-bold text-[var(--color-navy)]">
          Our PM Process
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          From initial inquiry to post-visit reporting, here's how a Surgiquip preventive maintenance engagement works — clear steps, no surprises.
        </p>
        <ol class="mt-6 space-y-4">
          {[
            ['Inquiry', 'You call or request a PM proposal — we learn about your facility and equipment.'],
            ['Equipment Assessment', 'We inventory every piece of equipment and document current condition and service history.'],
            ['Frequency Planning', 'We determine the right PM schedule for each item — quarterly, semi-annual, or annual — based on equipment type and manufacturer recommendations.'],
            ['Proposal', 'You receive a detailed proposal with each piece of equipment broken out by visit frequency and cost.'],
            ['Sign-Off', 'Once approved, we schedule your first PM visit around your OR calendar.'],
            ['Scheduled PM Visits', 'Our technicians follow the manufacturer\'s suggested preventative maintenance schedule for each item — inspections, testing, parts replacement, and calibration.'],
            ['Post-Visit Report', 'After every visit, you receive a detailed report of what was inspected, tested, replaced, and recommended.'],
          ].map(([title, desc], i) => (
            <li class="flex gap-4">
              <div class="shrink-0 w-8 h-8 rounded-full bg-[var(--color-blue)] text-white flex items-center justify-center text-sm font-bold">{i + 1}</div>
              <div>
                <div class="font-semibold text-[var(--color-navy)]">{title}</div>
                <div class="text-xs text-[var(--color-text-muted)] mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
      <div class="space-y-4">
        {[
          ['Reduced Emergency Repairs', 'Proactive part replacement eliminates 80%+ of emergency calls for maintained equipment.'],
          ['Extended Equipment Life', 'Proper maintenance extends surgical table and light lifespan by 3–5 years beyond typical.'],
          ['Predictable Budgeting', 'Annual PM costs are a fraction of a single emergency repair or premature replacement.'],
          ['Staff Confidence', 'Surgeons and OR nurses perform better when they trust the equipment won\'t fail mid-case.'],
        ].map(([title, desc]) => (
          <div class="p-5 bg-[var(--color-surface-alt)] rounded-lg border border-[var(--color-border)]">
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--color-blue)] mt-2 shrink-0"></div>
              <div>
                <div class="font-semibold text-[var(--color-navy)]">{title}</div>
                <div class="text-sm text-[var(--color-text-muted)] mt-1">{desc}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQSection
    eyebrow="Preventive Maintenance FAQ"
    heading="Common Questions About OR Equipment PM Programs"
    items={pmFAQs}
    bg="white"
  />

  <CTASection
    heading="Protect Your OR Investment"
    subhead="Get a PM proposal for your facility. We'll inventory your equipment and recommend the right program — quarterly, semi-annual, or annual."
    primaryLabel="Request PM Proposal"
  />
</BaseLayout>

