---
import BaseLayout from '~/layouts/BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  heading?: string;
  body?: string;
}
const {
  title,
  description,
  eyebrow = 'Coming Soon',
  heading = title,
  body = 'This page is part of our Phase 1 build. Full content is on the way. In the meantime, our team is ready to help — give us a call or request a quote.',
} = Astro.props;
import { site } from '~/data/site';
---
<BaseLayout title={title} description={description}>
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      <div class="text-xs font-bold tracking-widest uppercase text-white/70">{eyebrow}</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3 text-white">{heading}</h1>
    </div>
  </section>
  <section class="container-x py-16">
    <div class="max-w-3xl">
      <p class="text-lg text-[var(--color-text-muted)]">{body}</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/quote" class="btn-primary">Request Quote</a>
        <a href={`tel:${site.phoneE164}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-md border border-[var(--color-border)] font-semibold text-[var(--color-navy)] hover:border-[var(--color-navy)] transition">
          📞 {site.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
