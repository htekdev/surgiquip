---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTASection from '~/components/CTASection.astro';
import { site } from '~/data/site';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const canonicalUrl = `${site.url}/blog`;

/** Estimate reading time from raw markdown body text */
function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min read`;
}

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Surgical Equipment Resources & Insights | Surgiquip Solutions',
  description:
    'Expert insights on surgical equipment, OR installation planning, and healthcare facility management from Surgiquip Solutions — Houston\'s authorized Skytron dealer.',
  url: canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: site.brand,
    url: site.url,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: canonicalUrl },
  ],
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Surgical Equipment Resources & Insights | Surgiquip Solutions"
  description="Expert insights on surgical equipment, OR installation planning, and healthcare facility management from Surgiquip Solutions — Houston's authorized Skytron dealer since 1983."
  canonical={canonicalUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  {/* Page hero */}
  <section class="bg-[var(--color-navy)] text-white">
    <div class="container-x py-20">
      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li><a href="/" class="hover:text-white transition">Home</a></li>
          <li aria-hidden="true" class="text-white/40">›</li>
          <li class="text-white/90" aria-current="page">Blog</li>
        </ol>
      </nav>

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-xs font-semibold text-white/80 tracking-widest uppercase mb-6">
        Resources & Insights
      </div>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-white leading-tight max-w-3xl">
        Surgical Equipment Expertise for Texas Healthcare
      </h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl leading-relaxed">
        Planning an OR installation, evaluating equipment suppliers, or optimizing your facility's surgical suite? Our team shares practical insights from 43 years of field experience.
      </p>

      {/* RSS subscribe link */}
      <a
        href="/rss.xml"
        class="mt-6 inline-flex items-center gap-2 text-sm text-white/70 hover:text-white transition font-medium"
        aria-label="Subscribe to Surgiquip Solutions RSS feed"
      >
        <svg class="w-4 h-4 text-[#f97316]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        Subscribe via RSS
      </a>
    </div>
  </section>

  {/* Posts grid */}
  <section class="container-x py-16">
    {posts.length === 0 ? (
      <p class="text-[var(--color-text-muted)] text-center py-16">No posts yet — check back soon.</p>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-white hover:border-[var(--color-blue)] hover:shadow-lg transition overflow-hidden">
            {/* Hero image */}
            {post.data.image && (
              <div class="overflow-hidden aspect-[16/9] bg-[var(--color-surface-alt)]">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  width="768"
                  height="432"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              {/* Tags */}
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full bg-[var(--color-surface-alt)] text-[var(--color-blue)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <h2 class="font-display text-lg font-bold text-[var(--color-navy)] leading-snug mb-3 group-hover:text-[var(--color-blue)] transition">
                <a href={`/blog/${post.id}`} class="stretched-link">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
                {post.data.description}
              </p>
              <div class="mt-5 pt-4 border-t border-[var(--color-border)] flex items-center justify-between text-xs text-[var(--color-text-muted)]">
                <time datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
                <div class="flex items-center gap-3">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    {readingTime(post.body ?? '')}
                  </span>
                  <span class="text-[var(--color-blue)] font-semibold group-hover:underline">Read →</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <CTASection
    heading="43 Years of Surgical Equipment Expertise"
    subhead="From OR installations to preventive maintenance programs, Surgiquip Solutions serves hospitals and surgical centers across Southeast Texas."
    primaryLabel="Request a Quote"
    primaryHref="/quote"
    secondaryLabel="Call (713) 681-6362"
    secondaryHref="tel:+17136816362"
  />
</BaseLayout>
