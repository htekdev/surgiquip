---
/**
 * StickyMobileCTA.astro
 * 
 * Persistent bottom bar visible only on mobile (hidden lg:hidden).
 * Two equal-width buttons: Call + Request Quote.
 * Hospital procurement staff review on phones during rounds — this bar
 * ensures the conversion action is always one tap away.
 *
 * Spec ref: Epic B5 — "Sticky mobile CTA (Call + Request Quote)"
 */
import { site } from '~/data/site';
---

<!-- Sticky mobile CTA bar — hidden on desktop (lg+) -->
<div
  class="fixed bottom-0 left-0 right-0 z-50 lg:hidden"
  role="complementary"
  aria-label="Quick contact actions"
>
  <!-- Safe area backing (handles iPhone home indicator) -->
  <div class="bg-white border-t border-[var(--color-border)] shadow-[0_-4px_24px_rgba(10,44,94,0.12)]">
    <div class="flex items-stretch" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
      
      <!-- Call button -->
      <a
        href={`tel:${site.phoneE164}`}
        class="flex-1 flex items-center justify-center gap-2 py-3.5 px-4
               bg-[var(--color-navy)] text-white text-sm font-semibold
               active:bg-[var(--color-navy-dark)] transition-colors"
        aria-label={`Call Surgiquip at ${site.phone}`}
      >
        <!-- Phone icon -->
        <svg
          class="w-4 h-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.79 9.8 19.79 19.79 0 01.73 1.18 2 2 0 012.7 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L7.09 7.91a16 16 0 006.29 6.29l.87-.87a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
        <span>Call Now</span>
      </a>

      <!-- Vertical divider -->
      <div class="w-px bg-[var(--color-navy-dark)]/30 self-stretch"></div>

      <!-- Request Quote button -->
      <a
        href="/quote"
        class="flex-1 flex items-center justify-center gap-2 py-3.5 px-4
               bg-[var(--color-blue)] text-white text-sm font-semibold
               active:bg-[var(--color-blue-light)] transition-colors"
        aria-label="Request a quote from Surgiquip"
      >
        <!-- Document/clipboard icon -->
        <svg
          class="w-4 h-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        <span>Get Quote</span>
      </a>

    </div>
  </div>
</div>
